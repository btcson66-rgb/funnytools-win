---
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ToolCard from '../../../components/ToolCard.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE, type Locale } from '../../../config/site';
import { categories } from '../../../data/categories';
import { getFeaturedTools, getToolsByCategory } from '../../../data/tools';
import { t } from '../../../i18n/ui';
import { categoryUrl, localePath, absoluteUrl } from '../../../lib/url';
import { breadcrumbJsonLd } from '../../../lib/seo';

export function getStaticPaths() {
  return SITE.locales.map((lang) => ({
    params: { locale: lang === SITE.defaultLocale ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const ui = t(lang);
const title = ui.toolsPageTitle;
const description = ui.toolsPageDescription;

const featured = getFeaturedTools().slice(0, 6);

const categorySummaries = categories
  .map((category) => ({
    category,
    count: getToolsByCategory(category.id).filter((t) => t.status === 'live').length,
  }))
  .filter(({ count }) => count > 0);

const groupedCategories = categories
  .map((category) => ({
    category,
    tools: getToolsByCategory(category.id)
      .filter((tool) => tool.status === 'live')
      .map((tool) => ({
        tool,
        search: `${tool.name[lang]} ${tool.short[lang]}`.toLowerCase(),
      })),
  }))
  .filter(({ tools }) => tools.length > 0);

const faqItems = ui.toolsFaq;

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description: description,
  url: absoluteUrl(localePath(lang, 'tools')),
  inLanguage: SITE.hreflang[lang],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const breadcrumbLd = breadcrumbJsonLd([
  { name: ui.breadcrumbHome, href: localePath(lang) },
  { name: ui.toolsPageH1, href: localePath(lang, 'tools') },
]);
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  alternateSegments={['tools']}
  jsonLd={[collectionJsonLd, faqJsonLd, breadcrumbLd]}
>
  <!-- Breadcrumb -->
  <section class="wrap page-head">
    <Breadcrumb
      items={[
        { label: ui.breadcrumbHome, href: localePath(lang) },
        { label: ui.toolsPageH1 },
      ]}
    />
    <h1>{ui.toolsPageH1}</h1>
    <p class="lead">{ui.toolsPageIntro}</p>

    <!-- Search bar -->
    <label class="tools-search">
      <span>{ui.toolsSearch.label}</span>
      <input
        type="search"
        placeholder={ui.toolsSearch.placeholder}
        aria-label={ui.toolsSearch.label}
        autocomplete="off"
        data-tools-search
      />
    </label>
  </section>

  <!-- Popular tools -->
  {featured.length > 0 && (
    <section class="wrap content-section">
      <h2>{ui.popularTools}</h2>
      <div class="grid">
        {featured.map((tool) => <ToolCard lang={lang} tool={tool} />)}
      </div>
    </section>
  )}

  <!-- Category index -->
  <section id="categories" class="wrap content-section">
    <h2>{ui.categories}</h2>
    <div class="grid">
      {
        categorySummaries.map(({ category, count }) => (
          <a class="tile category-tile" href={categoryUrl(lang, category.id)}>
            <span class="tile-icon" aria-hidden="true">{category.icon}</span>
            <span class="tile-body">
              <strong>{category.name[lang]}</strong>
              <span>{category.description[lang]}</span>
              <span class="category-count">{count}{ui.toolsCountSuffix}</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- All tools by category (with search filtering) -->
  <section class="wrap tools-list">
    {
      groupedCategories.map(({ category, tools }) => (
        <section class="content-section tool-category-section" id={category.id} data-tool-section>
          <h2>{category.icon} {category.name[lang]}</h2>
          <p>{category.description[lang]}</p>
          <div class="grid">
            {
              tools.map(({ tool, search }) => (
                <div class="tool-search-item" data-search={search}>
                  <ToolCard lang={lang} tool={tool} />
                </div>
              ))
            }
          </div>
        </section>
      ))
    }
    <p class="empty-state" data-tools-empty aria-live="polite" hidden>{ui.toolsSearch.empty}</p>
  </section>

  <!-- How to use -->
  <section class="wrap content-section">
    <h2>{ui.toolsHowToUse.heading}</h2>
    <ol class="check-list">
      {ui.toolsHowToUse.steps.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <!-- Privacy & local processing -->
  <section class="wrap content-section">
    <h2>{ui.toolsPrivacy.heading}</h2>
    <p>{ui.toolsPrivacy.text}</p>
  </section>

  <!-- FAQ -->
  <section class="wrap content-section faq">
    <h2>{ui.faq}</h2>
    <dl>
      {
        faqItems.map((item) => (
          <>
            <dt>{item.q}</dt>
            <dd>{item.a}</dd>
          </>
        ))
      }
    </dl>
  </section>

  <!-- Footer links -->
  <section class="wrap content-section">
    <h2>{ui.toolsFooterLinks}</h2>
    <nav>
      <ul>
        <li><a href={localePath(lang, 'about')}>{ui.footer.about}</a></li>
        <li><a href={localePath(lang, 'privacy')}>{ui.footer.privacy}</a></li>
        <li><a href={localePath(lang, 'contact')}>{ui.footer.contact}</a></li>
      </ul>
    </nav>
  </section>

  <!-- Search script (unchanged) -->
  <script>
    const searchInput = document.querySelector('[data-tools-search]');
    const emptyState = document.querySelector('[data-tools-empty]');
    const sections = Array.from(document.querySelectorAll('[data-tool-section]'));

    if (searchInput instanceof HTMLInputElement && emptyState instanceof HTMLElement) {
      const initialQuery = new URLSearchParams(window.location.search).get('q');
      if (initialQuery) {
        searchInput.value = initialQuery;
      }

      const filterTools = () => {
        const query = searchInput.value.trim().toLowerCase();
        let visibleTotal = 0;

        sections.forEach((section) => {
          if (!(section instanceof HTMLElement)) return;

          const items = Array.from(section.querySelectorAll('[data-search]'));
          let visibleInSection = 0;

          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;

            const searchText = item.getAttribute('data-search') || '';
            const isVisible = query === '' || searchText.includes(query);
            item.hidden = !isVisible;

            if (isVisible) {
              visibleInSection += 1;
              visibleTotal += 1;
            }
          });

          section.hidden = visibleInSection === 0;
        });

        emptyState.hidden = visibleTotal > 0;
      };

      searchInput.addEventListener('input', filterTools);
      filterTools();
    }
  </script>
</BaseLayout>
