---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import { SITE, type Locale } from '../config/site';
import { absoluteUrl, assetPath, localePath } from '../lib/url';
import { buildHreflang, defaultOgImage } from '../lib/seo';
import { t } from '../i18n/ui';

interface Props {
  lang: Locale;
  title: string;
  description: string;
  keywords?: string[];
  type?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  alternateSegments?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  hasAlternates?: boolean;
  robots?: string;
}

const {
  lang,
  title,
  description,
  keywords = [],
  type = 'website',
  ogImage: customOgImage,
  ogImageAlt,
  alternateSegments = [],
  jsonLd = [],
  noindex = false,
  hasAlternates = true,
  robots,
} = Astro.props;

const canonical = absoluteUrl(localePath(lang, ...alternateSegments));
const hreflangs = buildHreflang(alternateSegments);
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const ogLocale = lang === 'zh' ? 'zh_TW' : 'en_US';
const ogImage = customOgImage ?? defaultOgImage();
const ogAlt = ogImageAlt ?? SITE.name[lang];
const brandedTitle = title.includes('FunnyTools') ? title : `${title} - FunnyTools`;
const brandedDescription = description;
const ui = t(lang);
const adsenseEnabled = SITE.adsenseEnabled || SITE.features.adsense;
const ga4Enabled = !!SITE.ga4MeasurementId;
const contentSecurityPolicy = [
  "default-src 'self'",
  `script-src 'self' 'unsafe-inline'${ga4Enabled ? ' https://www.googletagmanager.com' : ''}${adsenseEnabled ? ' https://pagead2.googlesyndication.com https://www.googletagservices.com https://adservice.google.com https://*.adtrafficquality.google' : ''}`,
  "style-src 'self' 'unsafe-inline'",
  `img-src 'self' data: blob:${ga4Enabled ? ' https://www.googletagmanager.com' : ''}${adsenseEnabled ? ' https://pagead2.googlesyndication.com https://*.googleusercontent.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://*.adtrafficquality.google' : ''}`,
  `frame-src 'self'${adsenseEnabled ? ' https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://*.adtrafficquality.google https://www.google.com' : ''}`,
  `connect-src 'self'${ga4Enabled ? ' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://analytics.google.com' : ''}${adsenseEnabled ? ' https://pagead2.googlesyndication.com https://*.adtrafficquality.google https://googleads.g.doubleclick.net https://csi.gstatic.com' : ''}`,
  "object-src 'none'",
  "base-uri 'self'",
  "form-action 'self'",
].join('; ');
---

<!doctype html>
<html lang={SITE.htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="icon" href={assetPath('favicon.ico')} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={assetPath('favicon.svg')} />
    <link rel="apple-touch-icon" sizes="180x180" href={assetPath('apple-touch-icon.png')} />
    <meta name="theme-color" content="#0d9488" />
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          const preferred = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.dataset.theme = saved || preferred;
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <title>{brandedTitle}</title>
    <meta name="description" content={brandedDescription} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    {noindex ? <meta name="robots" content="noindex, follow" /> : <link rel="canonical" href={canonical} />}
    {!noindex && robots && <meta name="robots" content={robots} />}
    {!noindex && hasAlternates && hreflangs.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
    <meta property="og:type" content={type} />
    <meta property="og:title" content={brandedTitle} />
    <meta property="og:description" content={brandedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogAlt} />
    <meta property="og:site_name" content={SITE.name[lang]} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={brandedTitle} />
    <meta name="twitter:description" content={brandedDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogAlt} />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    {
      ga4Enabled && (
        <>
          <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.ga4MeasurementId}`} />
          <script is:inline define:vars={{ measurementId: SITE.ga4MeasurementId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', measurementId);
          </script>
          <script is:inline>
            window.__ft_track = function(eventName, params) {
              if (typeof window.gtag === 'function') {
                var base = {
                  page_path: window.location.pathname,
                  language: document.documentElement.lang || 'zh-Hant'
                };
                var merged = {};
                for (var k in base) merged[k] = base[k];
                if (params) for (var k in params) merged[k] = params[k];
                window.gtag('event', eventName, merged);
              }
            };
          </script>
        </>
      )
    }
    {
      adsenseEnabled && (
        <>
          <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
          <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
        </>
      )
    }
    {
      adsenseEnabled && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#content">{ui.skipToContent}</a>
    <Nav lang={lang} segments={alternateSegments} showLangSwitch={hasAlternates} />
    <main id="content" class="site-main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
