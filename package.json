{
  "name": "funnytools",
  "version": "5.27.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "audit:adsense": "node scripts/adsense-preflight.mjs",
    "audit:analytics": "node scripts/analytics-preflight.mjs",
    "audit:pwa": "node scripts/pwa-preflight.mjs",
    "audit:security": "node scripts/security-preflight.mjs",
    "audit:lang-switch": "node scripts/lang-switch-audit.mjs",
    "audit:ui-dark": "node scripts/ui-dark-audit.mjs",
    "content:audit": "node scripts/content-quality-audit.mjs",
    "seo:audit": "node scripts/seo-system-audit.mjs",
    "seo:check": "node scripts/seo-crawlability-check.mjs",
    "audit:seo-collapse": "node scripts/seo-collapse-audit.mjs",
    "audit:seo-collapse:live": "node scripts/seo-collapse-audit.mjs --live",
    "seo:sitemap": "node scripts/generate-sitemaps.mjs",
    "seo:validate": "node scripts/validate-indexable-urls.mjs",
    "seo:indexnow": "node scripts/submit-indexnow.mjs",
    "seo:bing": "node scripts/submit-bing-urls.mjs",
    "seo:gsc-sitemaps": "node scripts/gsc-submit-sitemaps.mjs",
    "seo:gsc-inspect": "node scripts/gsc-inspect-priority-urls.mjs",
    "seo:all": "npm run seo:sitemap && npm run seo:validate && npm run seo:indexnow && npm run seo:bing && npm run seo:gsc-sitemaps",
    "report:analytics": "node scripts/analytics-report.mjs",
    "traffic-report": "node scripts/traffic-report/index.mjs",
    "daily-health": "node health-check.mjs",
    "preflight": "npm run build && npm run seo:sitemap && npm run seo:check && npm run audit:seo-collapse && npm run audit:lang-switch && npm run audit:adsense && npm run audit:analytics && npm run audit:pwa && npm run audit:security",
    "stats:site": "node scripts/site-stats.mjs",
    "release": "node scripts/site-stats.mjs && node scripts/release.mjs"
  },
  "dependencies": {
    "astro": "^6.4.7",
    "dompurify": "^3.4.11",
    "jsbarcode": "^3.12.1",
    "marked": "^18.0.5",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.5",
    "typescript": "^6.0.3"
  }
