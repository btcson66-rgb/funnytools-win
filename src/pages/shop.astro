---
import Breadcrumb from '../components/Breadcrumb.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { localePath, localeUrlPair } from '../lib/url';
import { breadcrumbJsonLd, collectionPageJsonLd } from '../lib/seo';
import {
  chemistryLine,
  learningProducts,
  physicsBundle,
  physicsSingles,
  withUtm,
} from '../data/shop-products';

const lang = 'zh' as const;
const title = 'Btcson Lab 教材商店';
const seoTitle = 'Btcson Lab 教材商店｜自然發音、數學、視覺日程與 STEM 實驗教材';
const description =
  'FunnyTools 團隊自製的可列印學習教材：CVC 自然發音閱讀、數學事實練習、晨間慣例、視覺日程卡、精細動作任務，以及物理與化學動手實驗任務包。PDF 下載、在家即可使用。';
const shopUrl = localePath(lang, 'shop');
const breadcrumbItems = [
  { name: '首頁', href: localePath(lang) },
  { name: '教材商店', href: shopUrl },
];
const jsonLd = [
  collectionPageJsonLd(lang, title, description, shopUrl),
  breadcrumbJsonLd(breadcrumbItems),
];
---

<BaseLayout
  lang={lang}
  title={seoTitle}
  description={description}
  alternateSegments={['shop']}
  altLang={localeUrlPair('shop')}
  robots="index, follow"
  jsonLd={jsonLd}
>
  <div class="shop-wrap">
    <section class="shop-hero">
      <Breadcrumb
        items={[
          { label: '首頁', href: localePath(lang) },
          { label: '教材商店' },
        ]}
      />
      <p class="eyebrow">教材商店</p>
      <h1>{title}</h1>
      <p class="lead">
        Btcson Lab 是 FunnyTools 團隊自製的教材品牌：可列印的閱讀、數學、日常慣例教材，
        以及在家就能做的物理、化學動手實驗任務包。全部是 PDF／離線檔案，購買後立即下載。
      </p>
    </section>

    <section class="content-section" aria-labelledby="learning-heading">
      <div class="section-head">
        <h2 id="learning-heading">學習教材（4–10 歲）</h2>
        <p>每套教材都含完整課次規劃與家長引導，列印出來就能開始。</p>
      </div>
      <div class="shop-grid">
        {learningProducts.map((p) => (
          <article class="shop-card">
            <span class="shop-icon" aria-hidden="true">{p.emoji}</span>
            <h3>{p.name[lang]}</h3>
            <p class="shop-meta">{p.meta[lang]}</p>
            <p>{p.blurb[lang]}</p>
            <p class="shop-price">{p.price}</p>
            <div class="shop-actions">
              {p.gumroad && (
                <a
                  class="btn"
                  href={withUtm(p.gumroad)}
                  target="_blank"
                  rel="noopener"
                  data-shop-product={p.id}
                  data-shop-platform="gumroad"
                >Gumroad 購買</a>
              )}
              {p.payhip && (
                <a
                  class="btn ghost"
                  href={withUtm(p.payhip)}
                  target="_blank"
                  rel="noopener"
                  data-shop-product={p.id}
                  data-shop-platform="payhip"
                >Payhip 購買</a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="stem-heading">
      <div class="section-head">
        <h2 id="stem-heading">STEM 動手實驗任務包（7–15 歲）</h2>
        <p>真材料、真實驗：每包含步驟圖解、家長指南、工作紙、小測驗、證書與離線模擬器。</p>
      </div>
      <div class="shop-grid shop-grid-wide">
        {[physicsBundle, chemistryLine].map((p) => (
          <article class="shop-card">
            <span class="shop-icon" aria-hidden="true">{p.emoji}</span>
            <h3>{p.name[lang]}</h3>
            <p class="shop-meta">{p.meta[lang]}</p>
            <p>{p.blurb[lang]}</p>
            <p class="shop-price">{p.price}</p>
            <div class="shop-actions">
              {p.gumroad && (
                <a
                  class="btn"
                  href={withUtm(p.gumroad)}
                  target="_blank"
                  rel="noopener"
                  data-shop-product={p.id}
                  data-shop-platform="gumroad"
                >Gumroad 購買</a>
              )}
              {p.payhip && (
                <a
                  class="btn ghost"
                  href={withUtm(p.payhip)}
                  target="_blank"
                  rel="noopener"
                  data-shop-product={p.id}
                  data-shop-platform="payhip"
                >Payhip 購買</a>
              )}
            </div>
          </article>
        ))}
      </div>

      <details class="shop-singles">
        <summary>物理任務包也可單包購買（每包 US$3，Payhip）</summary>
        <ul>
          {physicsSingles.map((s) => (
            <li>
              <a
                href={withUtm(s.payhip)}
                target="_blank"
                rel="noopener"
                data-shop-product="physics-single"
                data-shop-platform="payhip"
              >{s.name[lang]}</a>
            </li>
          ))}
        </ul>
      </details>
    </section>

    <section class="content-section shop-disclosure" aria-labelledby="disclosure-heading">
      <h2 id="disclosure-heading">關於這些商品</h2>
      <p>
        本頁商品均為 FunnyTools 營運團隊（Btcson Lab）自行設計製作的數位教材，非第三方分潤商品。
        交易與檔案下載在 Gumroad 或 Payhip 平台完成，付款與退款政策以平台頁面為準。
        購買前請先確認商品頁的內容說明與適用年齡。
      </p>
    </section>
  </div>

  <script>
    document.querySelectorAll('[data-shop-product]').forEach((link) => {
      link.addEventListener('click', () => {
        window.__ft_track?.('shop_click', {
          product: link.getAttribute('data-shop-product') || 'unknown',
          platform: link.getAttribute('data-shop-platform') || 'unknown',
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .shop-wrap {
    width: min(100% - 32px, 960px);
    margin-inline: auto;
  }

  .shop-hero {
    margin-top: 20px;
    padding: 28px 24px 30px;
    border: 1px solid rgba(219, 227, 238, 0.72);
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(15, 143, 140, 0.12), rgba(62, 99, 221, 0.08) 62%, rgba(242, 107, 79, 0.08)),
      #fff;
  }

  .shop-hero h1 {
    max-width: 760px;
  }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .shop-grid-wide {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .shop-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--card);
    box-shadow: var(--shadow-soft);
  }

  .shop-card h3,
  .shop-card p {
    margin: 0;
  }

  .shop-card h3 {
    margin-top: 12px;
    font-size: 1.08rem;
  }

  .shop-card p {
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .shop-icon {
    display: inline-grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 13px;
    background: var(--soft);
    font-size: 1.35rem;
  }

  .shop-meta {
    color: var(--brand-2) !important;
    font-size: 0.78rem !important;
    font-weight: 700;
  }

  .shop-price {
    margin-top: 12px !important;
    color: var(--ink) !important;
    font-size: 1.05rem !important;
    font-weight: 900;
  }

  .shop-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    width: 100%;
    margin-top: 12px;
    padding-top: 2px;
  }

  .shop-actions .btn {
    min-height: 40px;
    padding: 8px 10px;
    font-size: 0.88rem;
    text-align: center;
  }

  .shop-singles {
    margin-top: 18px;
    padding: 16px 20px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--card);
  }

  .shop-singles summary {
    color: var(--ink);
    font-weight: 800;
    cursor: pointer;
  }

  .shop-singles ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px 16px;
    margin: 14px 0 0;
    padding: 0 0 0 18px;
  }

  .shop-singles a {
    color: var(--brand-2);
  }

  .shop-disclosure {
    padding: 20px;
    border: 1px solid var(--line);
    border-left: 4px solid var(--brand);
    border-radius: 14px;
    background: var(--soft);
  }

  .shop-disclosure h2,
  .shop-disclosure p {
    margin: 0;
  }

  .shop-disclosure p {
    margin-top: 8px;
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .shop-grid,
    .shop-grid-wide {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .shop-hero {
      padding: 24px 16px;
      border-radius: 20px;
    }

    .shop-grid,
    .shop-grid-wide {
      grid-template-columns: 1fr;
    }

    .shop-singles ul {
      grid-template-columns: 1fr;
    }
  }
</style>
