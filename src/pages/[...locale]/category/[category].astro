---
import Breadcrumb from '../../../components/Breadcrumb.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE, type Locale } from '../../../config/site';
import { categories, getCategoryById, type Category } from '../../../data/categories';
import { getCategoryContent, type CategoryContent } from '../../../data/categoryContent';
import { getToolsByCategory } from '../../../data/tools';
import { t } from '../../../i18n/ui';
import { categoryUrl, localePath, toolUrl } from '../../../lib/url';
import { breadcrumbJsonLd, collectionPageJsonLd } from '../../../lib/seo';

export function getStaticPaths() {
  // Only generate pages for categories that actually have live tools,
  // so we never publish empty/thin category pages.
  const liveCategories = categories.filter((category) =>
    getToolsByCategory(category.id).some((tool) => tool.status === 'live'),
  );

  return SITE.locales.flatMap((lang) =>
    liveCategories.map((categoryData) => ({
      params: { locale: lang === SITE.defaultLocale ? undefined : lang, category: categoryData.id },
      props: { lang, categoryData },
    })),
  );
}

const { lang, categoryData } = Astro.props as { lang: Locale; categoryData: Category };
const ui = t(lang);
const content = getCategoryContent(categoryData.id) as CategoryContent | undefined;
const categoryTools = getToolsByCategory(categoryData.id).filter((tool) => tool.status === 'live');

const h1 = content ? content.h1[lang] : `${categoryData.icon} ${categoryData.name[lang]}`;
const pageTitle = content
  ? content.title[lang]
  : lang === 'zh'
    ? `${categoryData.name.zh.replace(/工具$/, '').trim()}免費工具｜${SITE.name.zh}`
    : `Free ${categoryData.name[lang]} Tools | ${SITE.name.en}`;
const pageDescription = content ? content.metaDescription[lang] : categoryData.description[lang];
const introParagraphs = content ? content.intro[lang] : [categoryData.description[lang]];
const useCases = content ? content.useCases[lang] : [];
const howToChoose = content ? content.howToChoose[lang] : [];
const faqItems = content ? content.faq[lang] : [];
const disclaimer = content?.disclaimer?.[lang];

const blurbFor = (slug: string): string =>
  content?.toolBlurbs[slug]?.[lang] ?? categoryTools.find((tool) => tool.slug === slug)?.short[lang] ?? '';

const relatedCategories = (content?.relatedCategories ?? [])
  .map((id) => getCategoryById(id))
  .filter((cat): cat is Category => cat != null)
  .filter((cat) => getToolsByCategory(cat.id).some((tool) => tool.status === 'live'));

const breadcrumbItems = [
  { name: ui.breadcrumbHome, href: localePath(lang) },
  { name: ui.allTools, href: localePath(lang, 'tools') },
  { name: categoryData.name[lang], href: categoryUrl(lang, categoryData.id) },
];

const jsonLd: Record<string, unknown>[] = [
  collectionPageJsonLd(lang, h1, pageDescription, categoryUrl(lang, categoryData.id)),
  breadcrumbJsonLd(breadcrumbItems),
];
if (faqItems.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  });
}
---

<BaseLayout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
  alternateSegments={['category', categoryData.id]}
  jsonLd={jsonLd}
>
  <section class="wrap page-head">
    <Breadcrumb
      items={[
        { label: ui.breadcrumbHome, href: localePath(lang) },
        { label: ui.allTools, href: localePath(lang, 'tools') },
        { label: categoryData.name[lang], href: categoryUrl(lang, categoryData.id) },
      ]}
    />
    <h1>{categoryData.icon} {h1}</h1>
    {introParagraphs.length > 0 && <p class="lead">{introParagraphs[0]}</p>}
    <p class="category-count-line">{ui.category.toolCountLabel}：{categoryTools.length}{ui.toolsCountSuffix}</p>
  </section>

  {introParagraphs.length > 1 && (
    <section class="wrap content-section category-intro">
      {introParagraphs.slice(1).map((paragraph) => <p>{paragraph}</p>)}
    </section>
  )}

  {disclaimer && (
    <section class="wrap content-section">
      <div class="disclaimer-callout" role="note">
        <strong>{ui.category.disclaimerHeading}</strong>
        <p>{disclaimer}</p>
      </div>
    </section>
  )}

  {useCases.length > 0 && (
    <section class="wrap content-section">
      <h2>{ui.category.useCasesHeading}</h2>
      <ul class="check-list">
        {useCases.map((useCase) => <li>{useCase}</li>)}
      </ul>
    </section>
  )}

  <section class="wrap content-section">
    <h2>{ui.category.recommendedHeading}</h2>
    <div class="tool-blurb-grid">
      {
        categoryTools.map((tool) => (
          <article class="tool-blurb-card">
            <h3>
              <span class="tile-icon" aria-hidden="true">{tool.icon}</span>
              {tool.name[lang]}
            </h3>
            <p>{blurbFor(tool.slug)}</p>
            <a class="btn go tool-blurb-cta" href={toolUrl(lang, tool.slug)}>
              {ui.category.goToTool}：{tool.name[lang]}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  {howToChoose.length > 0 && (
    <section class="wrap content-section">
      <h2>{ui.category.howToChooseHeading}</h2>
      <ul class="how-to-choose">
        {
          howToChoose.map((item) => (
            <li>
              {item.toolSlug ? (
                <a href={toolUrl(lang, item.toolSlug)}>{item.tip}</a>
              ) : (
                <span>{item.tip}</span>
              )}
            </li>
          ))
        }
      </ul>
    </section>
  )}

  {faqItems.length > 0 && (
    <section class="wrap content-section faq">
      <h2>{ui.faq}</h2>
      <dl>
        {
          faqItems.map((item) => (
            <>
              <dt>{item.q}</dt>
              <dd>{item.a}</dd>
            </>
          ))
        }
      </dl>
    </section>
  )}

  {relatedCategories.length > 0 && (
    <section class="wrap content-section">
      <h2>{ui.category.relatedHeading}</h2>
      <div class="grid">
        {
          relatedCategories.map((cat) => (
            <a class="tile category-tile" href={categoryUrl(lang, cat.id)}>
              <span class="tile-icon" aria-hidden="true">{cat.icon}</span>
              <span class="tile-body">
                <strong>{cat.name[lang]}</strong>
                <span>{cat.description[lang]}</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>
  )}
</BaseLayout>
