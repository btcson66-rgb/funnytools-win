---
import ToolCard from '../../components/ToolCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, type Locale } from '../../config/site';
import { categories } from '../../data/categories';
import { getFeaturedTools, getNewTools, getToolsByCategory, liveTools } from '../../data/tools';
import { home, homeFaq } from '../../i18n/pages';
import { t } from '../../i18n/ui';
import { categoryUrl, localePath } from '../../lib/url';
import { websiteJsonLd } from '../../lib/seo';

export function getStaticPaths() {
  return SITE.locales.map((lang) => ({
    params: { locale: lang === SITE.defaultLocale ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const copy = home[lang];
const ui = t(lang);
const featured = getFeaturedTools().slice(0, 6);
const newest = getNewTools().slice(0, 6);
const categorySummaries = categories
  .map((category) => ({
    category,
    count: getToolsByCategory(category.id).filter((t) => t.status === 'live').length,
  }))
  .filter(({ count }) => count > 0);
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaq[lang].map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout
  lang={lang}
  title={copy.seoTitle}
  description={copy.seoDescription}
  alternateSegments={[]}
  jsonLd={[websiteJsonLd(lang), faqJsonLd]}
>
  <section class="hero wrap">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p class="lead">{copy.intro}</p>
    <div class="hero-actions">
      <a class="btn go" href={localePath(lang, 'tools')}>{copy.primaryCta}</a>
      <a class="btn ghost" href="#categories">{copy.secondaryCta}</a>
    </div>
    <div class="hero-stats" aria-label={ui.categories}>
      <span class="stat-chip">
        <strong>{liveTools.length}+</strong>
        <span>{ui.heroStats.toolsLabel}</span>
      </span>
      <span class="stat-chip">
        <strong>{categories.length}</strong>
        <span>{ui.heroStats.categoriesLabel}</span>
      </span>
      <span class="stat-chip text-only">{ui.heroStats.noSignup}</span>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="wrap content-section">
      <h2>{ui.popularTools}</h2>
      <div class="grid">
        {featured.map((tool) => <ToolCard lang={lang} tool={tool} />)}
      </div>
    </section>
  )}

  {newest.length > 0 && (
    <section class="wrap content-section">
      <h2>{ui.newest}</h2>
      <div class="grid">
        {newest.map((tool) => <ToolCard lang={lang} tool={tool} />)}
      </div>
    </section>
  )}

  <section id="categories" class="wrap content-section">
    <h2>{ui.categories}</h2>
    <div class="grid">
      {
        categorySummaries.map(({ category, count }) => (
          <a class="tile category-tile" href={categoryUrl(lang, category.id)}>
            <span class="tile-icon" aria-hidden="true">{category.icon}</span>
            <span class="tile-body">
              <strong>{category.name[lang]}</strong>
              <span>{category.description[lang]}</span>
              <span class="category-count">{count}{ui.toolsCountSuffix}</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="wrap content-section why">
    <h2>{ui.whyUseThisSite}</h2>
    <ul class="check-list">
      {ui.homeWhy.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="wrap content-section faq">
    <h2>{ui.faq}</h2>
    <dl>
      {
        homeFaq[lang].map((item) => (
          <>
            <dt>{item.q}</dt>
            <dd>{item.a}</dd>
          </>
        ))
      }
    </dl>
  </section>
</BaseLayout>
