---
import Breadcrumb from '../../../components/Breadcrumb.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { allBlogPosts } from '../../../data/allBlogPosts';
import {
  isPostAvailableInLocale,
  viewBlogPost,
  type BlogPost,
  type BlogPostView,
} from '../../../data/blogPosts';
import { SITE, type Locale } from '../../../config/site';
import { absoluteUrl, categoryUrl, localePath, toolUrl } from '../../../lib/url';
import { breadcrumbJsonLd } from '../../../lib/seo';
import { t } from '../../../i18n/ui';

export function getStaticPaths() {
  return allBlogPosts.flatMap((post) => {
    const paths = [
      {
        params: { locale: undefined, slug: post.slug },
        props: { lang: 'zh' as const, post },
      },
    ];

    if (isPostAvailableInLocale(post, 'en')) {
      paths.push({
        params: { locale: 'en', slug: post.slug },
        props: { lang: 'en' as const, post },
      });
    }

    return paths;
  });
}

const { lang, post: sourcePost } = Astro.props as { lang: Locale; post: BlogPost };
const ui = t(lang);
const post = viewBlogPost(sourcePost, lang);
const articlePath = localePath(lang, 'blog', post.slug);
const articleUrl = absoluteUrl(articlePath);
const blogPath = localePath(lang, 'blog');
const relatedPosts: BlogPostView[] = (post.relatedArticleSlugs ?? [])
  .map((slug) => allBlogPosts.find((candidate) => candidate.slug === slug))
  .filter((candidate): candidate is BlogPost => candidate != null && isPostAvailableInLocale(candidate, lang))
  .map((candidate) => viewBlogPost(candidate, lang));
const hasAlternates = sourcePost.locales.includes('zh') && sourcePost.locales.includes('en');

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  datePublished: post.published,
  dateModified: post.updated,
  inLanguage: SITE.hreflang[lang],
  mainEntityOfPage: articleUrl,
  url: articleUrl,
  author: { '@type': 'Organization', name: SITE.name[lang], url: SITE.url },
  publisher: { '@type': 'Organization', name: SITE.name[lang], url: SITE.url },
};
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
const breadcrumbLd = breadcrumbJsonLd([
  { name: ui.breadcrumbHome, href: localePath(lang) },
  { name: ui.blog.breadcrumbLabel, href: blogPath },
  { name: post.title, href: articlePath },
]);
---

<BaseLayout
  lang={lang}
  title={post.title}
  description={post.description}
  type="article"
  alternateSegments={['blog', post.slug]}
  hasAlternates={hasAlternates}
  jsonLd={[articleLd, faqLd, breadcrumbLd]}
>
  <article class="wrap blog-article">
    <Breadcrumb items={[
      { label: ui.breadcrumbHome, href: localePath(lang) },
      { label: ui.blog.breadcrumbLabel, href: blogPath },
      { label: post.title },
    ]} />

    <header class="article-head">
      <p class="eyebrow">{ui.blog.eyebrowArticle}</p>
      <h1>{post.title}</h1>
      <p class="lead">{post.summary}</p>
      <p class="article-date">
        {ui.blog.publishedPrefix}<time datetime={post.published}>{post.published}</time>
        <span aria-hidden="true">{ui.blog.dateSeparator}</span>
        {ui.blog.updatedPrefix}<time datetime={post.updated}>{post.updated}</time>
      </p>
    </header>

    <aside class="tool-callout" aria-labelledby="related-tools-title">
      <h2 id="related-tools-title">{ui.blog.relatedToolsHeading}</h2>
      {post.categorySlug && (
        <p class="article-category-link">
          {ui.blog.categoryPrefix}<a href={categoryUrl(lang, post.categorySlug)}>{post.categoryLabel ?? post.categorySlug}</a>
        </p>
      )}
      <div class="tool-links">
        {post.toolLinks.map((tool) => (
          <a href={toolUrl(lang, tool.slug)}>
            <strong>{tool.label}</strong>
            <span>{tool.note}</span>
          </a>
        ))}
      </div>
    </aside>

    <div class="article-body">
      {post.sections.map((section) => (
        <section>
          <h2>{section.heading}</h2>
          {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          {section.subsections?.map((subsection) => (
            <section class="article-subsection">
              <h3>{subsection.heading}</h3>
              {subsection.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </section>
          ))}
        </section>
      ))}
    </div>

    <section class="article-faq faq" aria-labelledby="faq-title">
      <h2 id="faq-title">{ui.blog.faqHeading}</h2>
      <dl>
        {post.faq.map((item) => (
          <>
            <dt>{item.question}</dt>
            <dd>{item.answer}</dd>
          </>
        ))}
      </dl>
    </section>

    {relatedPosts.length > 0 && (
      <section class="article-related content-section" aria-labelledby="related-articles-title">
        <h2 id="related-articles-title">{ui.blog.relatedArticlesHeading}</h2>
        <div class="related-article-list">
          {relatedPosts.map((related) => (
            <a href={localePath(lang, 'blog', related.slug)}>
              <strong>{related.title}</strong>
              <span>{related.summary}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <nav class="article-bottom" aria-label={ui.blog.bottomNavLabel}>
      <a class="btn" href={blogPath}>{ui.blog.backToBlog}</a>
      <a class="btn go" href={toolUrl(lang, post.toolLinks[0].slug)}>{ui.blog.openToolPrefix}{post.toolLinks[0].label}</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .blog-article { max-width: 900px; padding-top: 34px; }
  .article-head { padding-bottom: 12px; }
  .article-head h1 { max-width: 860px; font-size: clamp(2rem, 6vw, 3.5rem); }
  .article-date { margin: 18px 0 0; color: var(--muted); font-size: 0.92rem; font-weight: 700; }
  .tool-callout { margin-top: 26px; padding: 20px; border: 1px solid #cfe6e3; border-radius: 14px; background: #f2fbfa; }
  .tool-callout h2 { margin-bottom: 12px; }
  .tool-links { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
  .article-category-link { margin: 0 0 12px; color: var(--muted); font-weight: 800; }
  .article-category-link a { color: var(--brand-2); }
  .tool-links a { display: grid; gap: 5px; padding: 14px; border: 1px solid rgba(15, 143, 140, 0.2); border-radius: 12px; background: #fff; }
  .tool-links a:hover { border-color: var(--brand); }
  .tool-links span { color: var(--muted); font-size: 0.88rem; line-height: 1.5; }
  .article-body { margin-top: 36px; }
  .article-body > section { margin-top: 38px; }
  .article-body p, .article-faq dd { color: #384455; font-size: 1.04rem; line-height: 1.9; }
  .article-subsection { margin-top: 26px; padding-left: 18px; border-left: 3px solid #d9e5ef; }
  .article-subsection h3 { margin: 0 0 10px; font-size: 1.15rem; }
  .article-faq { margin-top: 44px; padding: 22px; border: 1px solid var(--line); border-radius: 14px; background: var(--card); }
  .article-faq dt { font-size: 1.02rem; }
  .related-article-list { display: grid; gap: 10px; }
  .related-article-list a { display: grid; gap: 5px; padding: 14px; border: 1px solid var(--line); border-radius: 10px; background: #fff; }
  .related-article-list span { color: var(--muted); line-height: 1.6; }
  .article-bottom { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 12px; margin: 28px 0 48px; }
  @media (max-width: 760px) { .tool-links { grid-template-columns: 1fr; } .article-subsection { padding-left: 13px; } .article-faq { padding: 18px; } }
</style>
