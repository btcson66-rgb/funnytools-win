---
import Breadcrumb from '../../../components/Breadcrumb.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import type { Locale } from '../../../config/site';
import { localePath } from '../../../lib/url';
import { breadcrumbJsonLd } from '../../../lib/seo';
import { t } from '../../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { locale: undefined }, props: { lang: 'zh' } },
    { params: { locale: 'en' }, props: { lang: 'en' } },
  ];
}

const { lang } = Astro.props as { lang: Locale };
const ui = t(lang);
const title = ui.blog.indexTitle;
const description = ui.blog.indexDescription;
const blogUrl = localePath(lang, 'blog');
const breadcrumbLd = breadcrumbJsonLd([
  { name: ui.breadcrumbHome, href: localePath(lang) },
  { name: ui.blog.breadcrumbLabel, href: blogUrl },
]);
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  alternateSegments={['blog']}
  hasAlternates={true}
  jsonLd={[breadcrumbLd]}
  noindex={true}
>
  <section class="wrap page-head blog-head">
    <Breadcrumb items={[{ label: ui.breadcrumbHome, href: localePath(lang) }, { label: ui.blog.breadcrumbLabel }]} />
    <p class="eyebrow">{ui.blog.eyebrowIndex}</p>
    <h1>{title}</h1>
    <p class="lead">{ui.blog.indexLead}</p>
    <a class="btn go" href={localePath(lang, 'guides')}>{ui.blog.guidesCta}</a>
  </section>
</BaseLayout>

<style>
  .blog-head { padding-bottom: 8px; display: grid; gap: 14px; justify-items: start; }
</style>
