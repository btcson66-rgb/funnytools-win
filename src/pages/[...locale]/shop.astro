---
import Breadcrumb from '../../components/Breadcrumb.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localePath, localeUrlPair } from '../../lib/url';
import { breadcrumbJsonLd, collectionPageJsonLd } from '../../lib/seo';
import {
  chemistryLine,
  entitleKit,
  learningProducts,
  physicsBundle,
  physicsSingles,
  withUtm,
} from '../../data/shop-products';

export function getStaticPaths() {
  return [{ params: { locale: 'en' }, props: { lang: 'en' } }];
}

const lang = 'en' as const;
const title = 'Btcson Lab Store';
const seoTitle = 'Btcson Lab Store — printable phonics, math, routines & STEM kits';
const description =
  'Printable learning materials made by the FunnyTools team: CVC phonics reading, math fact practice, morning routines, visual schedules, fine-motor missions, plus hands-on physics and chemistry experiment packs. Instant PDF downloads.';
const shopUrl = localePath(lang, 'shop');
const breadcrumbItems = [
  { name: 'Home', href: localePath(lang) },
  { name: 'Store', href: shopUrl },
];
const jsonLd = [
  collectionPageJsonLd(lang, title, description, shopUrl),
  breadcrumbJsonLd(breadcrumbItems),
];
---

<BaseLayout
  lang={lang}
  title={seoTitle}
  description={description}
  alternateSegments={['shop']}
  altLang={localeUrlPair('shop')}
  robots="index, follow"
  jsonLd={jsonLd}
>
  <div class="shop-wrap">
    <section class="shop-hero">
      <Breadcrumb
        items={[
          { label: 'Home', href: localePath(lang) },
          { label: 'Store' },
        ]}
      />
      <p class="eyebrow">Store</p>
      <h1>{title}</h1>
      <p class="lead">
        Btcson Lab is the learning-materials brand from the FunnyTools team: printable reading,
        math, and daily-routine kits, plus hands-on physics and chemistry mission packs you can
        run at home. Everything is a PDF or offline file — download instantly after purchase.
      </p>
    </section>

    <section class="content-section" aria-labelledby="developer-heading">
      <div class="section-head">
        <p class="shop-kicker">SELF-HOSTED SOURCE KIT</p>
        <h2 id="developer-heading">Tools for indie software sellers</h2>
        <p>Selling software through Gumroad or Payhip? Connect checkout events to access you can verify and revoke.</p>
      </div>
      <div class="shop-grid shop-grid-featured">
        <article class="shop-card shop-card-featured">
          <span class="shop-icon" aria-hidden="true">{entitleKit.emoji}</span>
          <h3>{entitleKit.name[lang]}</h3>
          <p class="shop-meta">{entitleKit.meta[lang]}</p>
          <p>{entitleKit.blurb[lang]}</p>
          <p class="shop-price">{entitleKit.price}</p>
          <div class="shop-actions">
            <a
              class="btn"
              href={withUtm(entitleKit.gumroad!, 'entitlekit_card_gumroad')}
              target="_blank"
              rel="noopener"
              data-shop-product={entitleKit.id}
              data-shop-platform="gumroad"
            >View on Gumroad</a>
            <a
              class="btn ghost"
              href={withUtm(entitleKit.payhip!, 'entitlekit_card_payhip')}
              target="_blank"
              rel="noopener"
              data-shop-product={entitleKit.id}
              data-shop-platform="payhip"
            >View on Payhip</a>
          </div>
        </article>
      </div>
    </section>

    <section class="content-section" aria-labelledby="learning-heading">
      <div class="section-head">
        <h2 id="learning-heading">Learning kits (ages 4–10)</h2>
        <p>Each kit ships with a full session plan and parent guidance — print and start.</p>
      </div>
      <div class="shop-grid">
        {learningProducts.map((p) => (
          <article class="shop-card">
            <span class="shop-icon" aria-hidden="true">{p.emoji}</span>
            <h3>{p.name[lang]}</h3>
            <p class="shop-meta">{p.meta[lang]}</p>
            <p>{p.blurb[lang]}</p>
            <p class="shop-price">{p.price}</p>
            <div class="shop-actions">
              {p.gumroad && (
                <a
                  class="btn"
                  href={withUtm(p.gumroad)}
                  target="_blank"
                  rel="noopener"
                  data-shop-product={p.id}
                  data-shop-platform="gumroad"
                >Buy on Gumroad</a>
              )}
              {p.payhip && (
                <a
                  class="btn ghost"
                  href={withUtm(p.payhip)}
                  target="_blank"
                  rel="noopener"
                  data-shop-product={p.id}
                  data-shop-platform="payhip"
                >Buy on Payhip</a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="stem-heading">
      <div class="section-head">
        <h2 id="stem-heading">Hands-on STEM mission packs (ages 7–15)</h2>
        <p>Real materials, real experiments: illustrated steps, parent guides, worksheets, quizzes, certificates, and offline simulators.</p>
      </div>
      <div class="shop-grid shop-grid-wide">
        {[physicsBundle, chemistryLine].map((p) => (
          <article class="shop-card">
            <span class="shop-icon" aria-hidden="true">{p.emoji}</span>
            <h3>{p.name[lang]}</h3>
            <p class="shop-meta">{p.meta[lang]}</p>
            <p>{p.blurb[lang]}</p>
            <p class="shop-price">{p.price}</p>
            <div class="shop-actions">
              {p.gumroad && (
                <a
                  class="btn"
                  href={withUtm(p.gumroad)}
                  target="_blank"
                  rel="noopener"
                  data-shop-product={p.id}
                  data-shop-platform="gumroad"
                >Buy on Gumroad</a>
              )}
              {p.payhip && (
                <a
                  class="btn ghost"
                  href={withUtm(p.payhip)}
                  target="_blank"
                  rel="noopener"
                  data-shop-product={p.id}
                  data-shop-platform="payhip"
                >Buy on Payhip</a>
              )}
            </div>
          </article>
        ))}
      </div>

      <details class="shop-singles">
        <summary>Physics packs are also sold individually (US$3 each on Payhip)</summary>
        <ul>
          {physicsSingles.map((s) => (
            <li>
              <a
                href={withUtm(s.payhip)}
                target="_blank"
                rel="noopener"
                data-shop-product="physics-single"
                data-shop-platform="payhip"
              >{s.name[lang]}</a>
            </li>
          ))}
        </ul>
      </details>
    </section>

    <section class="content-section shop-disclosure" aria-labelledby="disclosure-heading">
      <h2 id="disclosure-heading">About these products</h2>
      <p>
        Every product on this page is designed and produced by the FunnyTools team (Btcson Lab) —
        our own learning materials or software source-code tools, not third-party affiliate offers. Checkout and file delivery
        happen on Gumroad or Payhip; payment and refund policies follow the platform pages.
        Please review the product description and age range before buying.
      </p>
    </section>
  </div>

  <script>
    document.querySelectorAll('[data-shop-product]').forEach((link) => {
      link.addEventListener('click', () => {
        window.__ft_track?.('shop_click', {
          product: link.getAttribute('data-shop-product') || 'unknown',
          platform: link.getAttribute('data-shop-platform') || 'unknown',
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .shop-wrap {
    width: min(100% - 32px, 960px);
    margin-inline: auto;
  }

  .shop-hero {
    margin-top: 20px;
    padding: 28px 24px 30px;
    border: 1px solid rgba(219, 227, 238, 0.72);
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(15, 143, 140, 0.12), rgba(62, 99, 221, 0.08) 62%, rgba(242, 107, 79, 0.08)),
      #fff;
  }

  .shop-hero h1 {
    max-width: 760px;
  }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .shop-grid-wide {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .shop-grid-featured {
    grid-template-columns: minmax(0, 1fr);
  }

  .shop-card-featured {
    border-color: rgba(15, 143, 140, 0.35);
    background: linear-gradient(135deg, rgba(15, 143, 140, 0.09), rgba(62, 99, 221, 0.05)), var(--card);
  }

  .shop-card-featured h3 {
    font-size: 1.25rem;
  }

  .shop-kicker {
    margin: 0 0 6px;
    color: var(--brand-2);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .shop-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--card);
    box-shadow: var(--shadow-soft);
  }

  .shop-card h3,
  .shop-card p {
    margin: 0;
  }

  .shop-card h3 {
    margin-top: 12px;
    font-size: 1.08rem;
  }

  .shop-card p {
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .shop-icon {
    display: inline-grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 13px;
    background: var(--soft);
    font-size: 1.35rem;
  }

  .shop-meta {
    color: var(--brand-2) !important;
    font-size: 0.78rem !important;
    font-weight: 700;
  }

  .shop-price {
    margin-top: 12px !important;
    color: var(--ink) !important;
    font-size: 1.05rem !important;
    font-weight: 900;
  }

  .shop-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    width: 100%;
    margin-top: 12px;
    padding-top: 2px;
  }

  .shop-actions .btn {
    min-height: 40px;
    padding: 8px 10px;
    font-size: 0.88rem;
    text-align: center;
  }

  .shop-singles {
    margin-top: 18px;
    padding: 16px 20px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--card);
  }

  .shop-singles summary {
    color: var(--ink);
    font-weight: 800;
    cursor: pointer;
  }

  .shop-singles ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px 16px;
    margin: 14px 0 0;
    padding: 0 0 0 18px;
  }

  .shop-singles a {
    color: var(--brand-2);
  }

  .shop-disclosure {
    padding: 20px;
    border: 1px solid var(--line);
    border-left: 4px solid var(--brand);
    border-radius: 14px;
    background: var(--soft);
  }

  .shop-disclosure h2,
  .shop-disclosure p {
    margin: 0;
  }

  .shop-disclosure p {
    margin-top: 8px;
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .shop-grid,
    .shop-grid-wide {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .shop-hero {
      padding: 24px 16px;
      border-radius: 20px;
    }

    .shop-grid,
    .shop-grid-wide {
      grid-template-columns: 1fr;
    }

    .shop-singles ul {
      grid-template-columns: 1fr;
    }
  }
</style>
