---
import Breadcrumb from '../components/Breadcrumb.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { absoluteUrl, assetPath, localePath } from '../lib/url';
import { breadcrumbJsonLd, webPageJsonLd } from '../lib/seo';

const title = '支持 FreeTools 持續提供免費工具';
const seoTitle = '支持 FreeTools｜免費工具網站營運支持';
const description = 'FreeTools 提供免費線上工具，無需安裝也不需註冊。你可以透過分享網站、回報問題、建議新工具，或使用推薦資源連結，支持本站持續營運與更新。';
const supportUrl = localePath('zh', 'support');
const homeUrl = absoluteUrl(localePath('zh'));
const shareText = 'FreeTools 提供免費、免安裝的實用線上工具，推薦給你！';
const encodedHomeUrl = encodeURIComponent(homeUrl);
const encodedSharePost = encodeURIComponent(`${shareText} ${homeUrl}`);
const socialShareLinks = [
  {
    name: 'Facebook',
    shortLabel: 'f',
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedHomeUrl}`,
  },
  {
    name: 'LINE',
    shortLabel: 'LINE',
    href: `https://social-plugins.line.me/lineit/share?url=${encodedHomeUrl}`,
  },
  {
    name: 'X',
    shortLabel: 'X',
    href: `https://x.com/intent/post?text=${encodedSharePost}`,
  },
  {
    name: 'Threads',
    shortLabel: '@',
    href: `https://www.threads.net/intent/post?text=${encodedSharePost}`,
  },
];
const breadcrumbItems = [
  { name: '首頁', href: localePath('zh') },
  { name: '支持本站', href: supportUrl },
];
const jsonLd = [
  webPageJsonLd('zh', title, description, supportUrl),
  breadcrumbJsonLd(breadcrumbItems),
];
---

<BaseLayout
  lang="zh"
  title={seoTitle}
  description={description}
  alternateSegments={['support']}
  robots="index, follow"
  jsonLd={jsonLd}
>
  <div class="support-wrap">
    <section class="support-hero">
      <Breadcrumb
        items={[
          { label: '首頁', href: localePath('zh') },
          { label: '支持本站' },
        ]}
      />
      <p class="eyebrow">支持本站</p>
      <h1>{title}</h1>
      <p class="lead">
        FreeTools 希望持續提供簡單、免費、好用的線上工具。如果本站曾經幫你節省時間，你可以透過分享網站、回報錯誤、建議新工具，或使用我們整理的實用資源連結支持本站。
      </p>
    </section>

    <section class="content-section" aria-labelledby="support-methods-heading">
      <div class="section-head">
        <h2 id="support-methods-heading">你可以這樣支持 FreeTools</h2>
        <p>每一種方式都能幫助本站維持免費工具與內容更新。</p>
      </div>
      <div class="support-methods">
        <article class="support-method-card">
          <span class="support-icon" aria-hidden="true">↗</span>
          <h3>分享本站</h3>
          <p>把 FreeTools 分享給需要線上工具的朋友，可以幫助本站被更多人看見。</p>
          <div class="share-actions" aria-label="分享 FreeTools">
            {socialShareLinks.map((platform) => (
              <a
                class={`share-button share-${platform.name.toLowerCase()}`}
                href={platform.href}
                target="_blank"
                rel="noopener noreferrer"
                data-support-source={`share_${platform.name.toLowerCase()}`}
                aria-label={`分享到 ${platform.name}`}
                title={`分享到 ${platform.name}`}
              >
                <span aria-hidden="true">{platform.shortLabel}</span>
                <span>{platform.name}</span>
              </a>
            ))}
          </div>
          <button class="btn ghost copy-home-link" type="button" data-copy-home-link data-copy-url={homeUrl} data-support-source="copy_site_link">
            <span aria-hidden="true">⧉</span>
            <span data-copy-label>複製首頁連結</span>
          </button>
          <p class="copy-status" data-copy-status role="status" aria-live="polite"></p>
        </article>
        <article class="support-method-card">
          <span class="support-icon" aria-hidden="true">✉</span>
          <h3>回報錯誤或建議新工具</h3>
          <p>如果你發現工具無法正常使用，或希望新增某個實用工具，歡迎透過聯絡頁告訴我們。</p>
          <a class="inline-link" href={localePath('zh', 'contact')} data-support-source="feedback_contact">前往聯絡頁</a>
        </article>
        <article class="support-method-card">
          <span class="support-icon" aria-hidden="true">◇</span>
          <h3>使用推薦資源連結</h3>
          <p>部分資源連結可能包含分潤，購買價格不會增加，但可以支持本站維持營運。</p>
          <div class="support-card-actions">
            <a class="inline-link" href="#resources" data-support-source="view_resources">查看實用資源</a>
            <a
              class="btn support-home-link"
              href="https://coupa.ng/cnx9Rk"
              target="_blank"
              rel="sponsored nofollow noopener"
              data-support-source="affiliate_coupang"
            >前往酷澎自行選購</a>
          </div>
        </article>
      </div>
    </section>

    <section id="resources" class="content-section anchor-section" aria-labelledby="resources-heading">
      <div class="section-head resource-heading">
        <div>
          <h2 id="resources-heading">實用資源</h2>
          <p>依照檔案整理、工作效率、旅行、列印與拍攝等常見需求整理。</p>
        </div>
        <button class="btn ghost refresh-products" type="button" data-refresh-products disabled>
          <span aria-hidden="true">↻</span>
          換一批
        </button>
      </div>

      <aside class="affiliate-disclosure" aria-label="分潤連結透明說明">
        <strong>透明說明</strong>
        <p>
          本頁部分資源連結可能包含蝦皮、酷澎或其他平台的分潤連結。你透過這些連結購買商品時，購買價格不會因此增加，但本站可能會獲得少量回饋，用來維持網站營運與開發新工具。請依照自己的需求比較與選擇，本站不會因分潤而保證商品價格、庫存或適用性。
        </p>
      </aside>

      <p class="resource-note">每次會隨機顯示部分資源，你可以按「換一批」查看其他整理項目。</p>
      <p class="resource-status" data-resource-status role="status" aria-live="polite">正在整理資源…</p>
      <div class="support-product-grid" data-support-products aria-busy="true"></div>
      <noscript>
        <p class="empty-state">請啟用 JavaScript 以載入與切換實用資源。</p>
      </noscript>
    </section>

    <section class="content-section support-reminder" aria-labelledby="choose-heading">
      <h2 id="choose-heading">選擇前請先確認需求</h2>
      <p>商品資訊、庫存與適用性以平台頁面為準。建議先確認裝置規格、連接介面與實際用途，再決定是否需要購買。</p>
    </section>
  </div>

  <script src={`${assetPath('support-products.js')}?v=20260623-support-en`} defer></script>
  <script>
    const copyButton = document.querySelector('[data-copy-home-link]');
    const copyStatus = document.querySelector('[data-copy-status]');
    const copyLabel = copyButton?.querySelector('[data-copy-label]');

    const fallbackCopy = (text: string) => {
      const input = document.createElement('textarea');
      input.value = text;
      input.setAttribute('readonly', '');
      input.style.position = 'fixed';
      input.style.opacity = '0';
      document.body.append(input);
      input.select();
      const copied = document.execCommand('copy');
      input.remove();
      return copied;
    };

    copyButton?.addEventListener('click', async () => {
      const homeUrl = copyButton.getAttribute('data-copy-url');
      if (!homeUrl) return;
      window.__ft_track?.('support_click', {
        source: copyButton.getAttribute('data-support-source') || 'copy_site_link'
      });

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(homeUrl);
        } else if (!fallbackCopy(homeUrl)) {
          throw new Error('Copy failed');
        }

        if (copyLabel) copyLabel.textContent = '已複製首頁連結';
        if (copyStatus) copyStatus.textContent = 'FreeTools 首頁連結已複製。';
        window.setTimeout(() => {
          if (copyLabel) copyLabel.textContent = '複製首頁連結';
          if (copyStatus) copyStatus.textContent = '';
        }, 2400);
      } catch {
        if (copyStatus) copyStatus.textContent = `無法自動複製，請手動複製：${homeUrl}`;
      }
    });

    document.querySelectorAll('[data-support-source]').forEach((link) => {
      if (link === copyButton) return;
      link.addEventListener('click', () => {
        const source = link.getAttribute('data-support-source') || 'support_page';
        window.__ft_track?.('support_click', { source });
        if (source.startsWith('share_')) {
          window.__ft_track?.('share_click', { method: source.replace(/^share_/, '') });
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .support-wrap {
    width: min(100% - 32px, 960px);
    margin-inline: auto;
  }

  .support-hero {
    margin-top: 20px;
    padding: 28px 24px 30px;
    border: 1px solid rgba(219, 227, 238, 0.72);
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(15, 143, 140, 0.12), rgba(62, 99, 221, 0.08) 62%, rgba(242, 107, 79, 0.08)),
      #fff;
  }

  .support-hero h1 {
    max-width: 760px;
  }

  .support-methods {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .support-method-card {
    display: flex;
    min-height: 240px;
    flex-direction: column;
    align-items: flex-start;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--card);
    box-shadow: var(--shadow-soft);
  }

  .support-method-card h3,
  .support-method-card p {
    margin: 0;
  }

  .support-method-card h3 {
    margin-top: 14px;
    font-size: 1.08rem;
  }

  .support-method-card p {
    margin-top: 8px;
    color: var(--muted);
  }

  .support-method-card .inline-link {
    margin-top: auto;
    padding-top: 14px;
  }

  .share-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    width: 100%;
    margin-top: 16px;
  }

  .share-button {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    gap: 8px;
    justify-content: center;
    padding: 8px 10px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--card);
    color: var(--ink);
    font-size: 0.86rem;
    font-weight: 800;
    text-decoration: none;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }

  .share-button:hover {
    border-color: var(--brand);
    box-shadow: 0 7px 18px rgba(31, 47, 70, 0.1);
    transform: translateY(-1px);
  }

  .share-button:focus-visible,
  .copy-home-link:focus-visible {
    outline: 3px solid rgba(62, 99, 221, 0.28);
    outline-offset: 2px;
  }

  .share-button > span:first-child {
    display: inline-grid;
    width: 24px;
    height: 24px;
    place-items: center;
    border-radius: 7px;
    background: var(--soft);
    color: var(--brand-2);
    font-size: 0.76rem;
    font-weight: 900;
  }

  .share-facebook > span:first-child {
    background: #e9f0ff;
    color: #1877f2;
  }

  .share-line > span:first-child {
    background: #e8fbe9;
    color: #06a943;
    font-size: 0.55rem;
  }

  .share-x > span:first-child,
  .share-threads > span:first-child {
    background: #eef0f3;
    color: #111;
  }

  .copy-home-link {
    width: 100%;
    min-height: 42px;
    margin-top: 10px;
  }

  .copy-status {
    min-height: 1.35em;
    margin: 6px 0 0 !important;
    color: var(--brand) !important;
    font-size: 0.78rem;
  }

  .support-card-actions {
    display: grid;
    gap: 10px;
    width: 100%;
    margin-top: auto;
    padding-top: 14px;
  }

  .support-card-actions .inline-link {
    margin-top: 0;
    padding-top: 0;
  }

  .support-home-link {
    justify-self: start;
    min-height: 40px;
    padding: 8px 12px;
    font-size: 0.92rem;
  }

  .support-icon {
    display: inline-grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 13px;
    background: var(--soft);
    color: var(--brand);
    font-size: 1.25rem;
    font-weight: 900;
  }

  .resource-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }

  .resource-heading h2,
  .resource-heading p {
    margin: 0;
  }

  .refresh-products {
    flex: 0 0 auto;
    gap: 7px;
  }

  .affiliate-disclosure {
    padding: 18px 20px;
    border: 1px solid var(--line);
    border-left: 4px solid var(--brand);
    border-radius: 12px;
    background: var(--soft);
  }

  .affiliate-disclosure strong {
    color: #0b6f6b;
  }

  .affiliate-disclosure p {
    margin: 6px 0 0;
    color: #3f5f5d;
  }

  .resource-note,
  .resource-status {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .resource-note {
    margin: 14px 0 0;
  }

  .resource-status {
    min-height: 1.5em;
    margin: 6px 0 12px;
  }

  :global(.support-product-grid) {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  :global(.support-product-card) {
    display: flex;
    min-width: 0;
    min-height: 310px;
    flex-direction: column;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--card);
    box-shadow: var(--shadow-soft);
  }

  :global(.support-product-icon) {
    display: inline-grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(15, 143, 140, 0.13), rgba(62, 99, 221, 0.11));
    font-size: 1.35rem;
  }

  :global(.support-product-media) {
    display: grid;
    width: 100%;
    aspect-ratio: 1;
    place-items: center;
    overflow: hidden;
    border: 1px solid #e3e9f1;
    border-radius: 12px;
    background: var(--card);
  }

  :global(.support-product-media img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  :global(.support-product-platform) {
    align-self: flex-start;
    margin-top: 14px;
    padding: 3px 8px;
    border-radius: 999px;
    background: var(--bg);
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 800;
  }

  :global(.support-product-card h3) {
    margin: 10px 0 0;
    font-size: 1rem;
    line-height: 1.35;
  }

  :global(.support-product-card p) {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  :global(.support-product-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
  }

  :global(.support-product-tags li) {
    padding: 2px 7px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--brand-2);
    font-size: 0.72rem;
    font-weight: 700;
  }

  :global(.support-product-card .btn) {
    align-self: stretch;
    margin-top: auto;
    padding-top: 9px;
    padding-bottom: 9px;
  }

  .support-reminder {
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--card);
  }

  .support-reminder h2,
  .support-reminder p {
    margin: 0;
  }

  .support-reminder p {
    margin-top: 8px;
    color: var(--muted);
  }

  @media (max-width: 820px) {
    :global(.support-product-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .support-hero {
      padding: 24px 16px;
      border-radius: 20px;
    }

    .support-methods {
      grid-template-columns: 1fr;
    }

    .support-method-card {
      min-height: 0;
    }

    .support-method-card .inline-link {
      margin-top: 4px;
    }

    .resource-heading {
      align-items: stretch;
      flex-direction: column;
    }

    .refresh-products {
      align-self: flex-start;
    }
  }

  @media (max-width: 520px) {
    :global(.support-product-grid) {
      grid-template-columns: 1fr;
    }

    :global(.support-product-card) {
      min-height: 0;
    }
  }
</style>
