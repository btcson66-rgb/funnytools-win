---
import { SITE } from '../config/site';

// Manual ad units stay off until real ad-slot IDs replace the placeholder below.
const enabled = SITE.features.adsense;
---

{
  enabled && (
    <div class="ad-slot" aria-label="Advertisement">
      <ins
        class="adsbygoogle"
        data-ad-client={SITE.adsenseClient}
        data-ad-slot="0000000000"
        data-ad-format="auto"
        data-full-width-responsive="true"
      />
    </div>
  )
}

<style>
  /* Reserve vertical space so responsive ads don't push content down (CLS). */
  .ad-slot {
    min-height: 120px;
    display: grid;
    align-items: center;
    border-radius: 12px;
    background: color-mix(in srgb, var(--line) 25%, transparent);
  }

  .ad-slot :global(.adsbygoogle) {
    display: block;
    width: 100%;
  }

  @media (min-width: 768px) {
    .ad-slot {
      min-height: 280px;
    }
  }
</style>
