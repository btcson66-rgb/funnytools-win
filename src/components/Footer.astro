---
import { SITE, type Locale } from '../config/site';
import { t } from '../i18n/ui';
import { localePath } from '../lib/url';
import pkg from '../../package.json';
import siteStats from '../data/site-stats.json';

interface Props { lang: Locale; }

const { lang } = Astro.props;
const ui = t(lang);
const year = new Date().getFullYear();
const version = pkg.version;
const footerBrand = lang === 'zh' ? `${SITE.name.zh} by FunnyTools.win` : SITE.name.en;

// 累積數據為 GA4 真實快照（release 時由 scripts/site-stats.mjs 刷新）；
// 低於門檻不顯示，避免小數字造成反效果。
const STATS_MIN_PAGEVIEWS = 1000;
const stats = (siteStats as { sites?: Record<string, { pageviews: number; users: number }> }).sites?.['funnytools.win'];
const showStats = Boolean(stats && stats.pageviews >= STATS_MIN_PAGEVIEWS);
const fmt = (n: number) => n.toLocaleString('en-US');
const statsLine = stats
  ? (lang === 'zh'
    ? `累積瀏覽 ${fmt(stats.pageviews)} 次 · 累積使用者 ${fmt(stats.users)} 位`
    : `${fmt(stats.pageviews)} total views · ${fmt(stats.users)} users and counting`)
  : '';
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <strong>{SITE.name[lang]}</strong>
      <p>{SITE.tagline[lang]}</p>
    </div>
    <nav class="footer-links" aria-label={ui.ariaFooterNav}>
      <div>
        <span>{lang === 'zh' ? '工具入口' : 'Tool hubs'}</span>
        <a href={localePath(lang, 'tools')}>{ui.nav.tools}</a>
        <a href={localePath(lang, 'guides')}>{lang === 'zh' ? '使用教學' : 'Guides'}</a>
        <a href={localePath(lang, 'for')}>{lang === 'zh' ? '依使用情境找工具' : 'For your work'}</a>
        <a href={localePath(lang, 'workflows')}>{lang === 'zh' ? '工作流工具組' : 'Workflows'}</a>
      </div>
      <div>
        <span>{lang === 'zh' ? '關於本站' : 'About'}</span>
        <a href={localePath(lang, 'about')}>{ui.footer.about}</a>
        <a href={localePath(lang, 'about-tools')}>{ui.footer.aboutTools}</a>
        <a href={localePath(lang, 'contact')}>{ui.footer.contact}</a>
      </div>
      <div>
        <span>{lang === 'zh' ? '政策' : 'Policies'}</span>
        <a href={localePath(lang, 'privacy')}>{ui.footer.privacy}</a>
        <a href={localePath(lang, 'terms')}>{ui.footer.terms}</a>
        <a href={localePath(lang, 'disclaimer')}>{ui.footer.disclaimer}</a>
      </div>
      <div>
        <span>{lang === 'zh' ? '姊妹站' : 'Our other sites'}</span>
        <a href={lang === 'zh' ? 'https://worthcalc.win/zh/' : 'https://worthcalc.win/en/'} rel="noopener">{lang === 'zh' ? 'WorthCalc 值不值得計算機' : 'WorthCalc — is it worth it?'}</a>
        <a href={lang === 'zh' ? 'https://roomfeng.win/zh/' : 'https://roomfeng.win/en/'} rel="noopener">{lang === 'zh' ? 'RoomFeng 房間風水規劃' : 'RoomFeng room planner'}</a>
      </div>
    </nav>
  </div>
  <div class="footer-bottom">
    {showStats && <p class="fineprint site-stats" data-nosnippet>{statsLine}</p>}
    <p class="fineprint">&copy; {year} {footerBrand} · v{version}</p>
    <p>{ui.footer.legalNote}</p>
  </div>
</footer>
