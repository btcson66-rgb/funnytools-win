---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card" data-compound-interest-tool data-labels={JSON.stringify(labels)}>
  <div class="form-grid">
    <label>
      <span>{labels.principal}</span>
      <input data-principal type="number" min="0" step="100" value="10000" />
    </label>
    <label>
      <span>{labels.monthly}</span>
      <input data-monthly type="number" min="0" step="100" value="500" />
    </label>
    <label>
      <span>{labels.rate}</span>
      <input data-rate type="number" min="0" step="0.1" value="5" />
    </label>
    <label>
      <span>{labels.years}</span>
      <input data-years type="number" min="1" step="1" value="10" />
    </label>
    <label>
      <span>{labels.compounding}</span>
      <select data-compounding>
        <option value="12" selected>{labels.monthlyCompounding}</option>
        <option value="4">{labels.quarterlyCompounding}</option>
        <option value="1">{labels.yearlyCompounding}</option>
        <option value="365">{labels.dailyCompounding}</option>
      </select>
    </label>
  </div>

  <div class="actions">
    <button class="btn go" type="button" data-calculate>{labels.calculate}</button>
    <button class="btn ghost" type="button" data-copy>{labels.copy}</button>
  </div>

  <p class="form-error" data-error role="alert" hidden></p>
  <div class="stats-grid finance-stats" aria-live="polite">
    <div><span>{labels.futureValue}</span><strong data-future>-</strong></div>
    <div><span>{labels.contributed}</span><strong data-contributed>-</strong></div>
    <div><span>{labels.interest}</span><strong data-interest>-</strong></div>
  </div>

  <div class="chart-box">
    <h3>{labels.chartTitle}</h3>
    <svg data-chart viewBox="0 0 640 220" role="img" aria-label={labels.chartTitle}></svg>
  </div>
  <span class="toast" role="status" aria-live="polite" hidden>{labels.copied}</span>
</section>

<style>
  select {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--card);
    color: var(--ink);
    padding: 10px 12px;
    font: inherit;
  }

  .actions {
    margin: 16px 0;
  }

  .finance-stats {
    margin-bottom: 18px;
  }

  .chart-box {
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--soft);
  }

  .chart-box h3 {
    margin: 0 0 10px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  svg {
    display: block;
    width: 100%;
    min-height: 180px;
  }
</style>

<script>
  document.querySelectorAll('[data-compound-interest-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const inputs = {
      principal: root.querySelector('[data-principal]'),
      monthly: root.querySelector('[data-monthly]'),
      rate: root.querySelector('[data-rate]'),
      years: root.querySelector('[data-years]'),
      compounding: root.querySelector('[data-compounding]'),
    };
    const outputs = {
      future: root.querySelector('[data-future]'),
      contributed: root.querySelector('[data-contributed]'),
      interest: root.querySelector('[data-interest]'),
    };
    const chart = root.querySelector('[data-chart]');
    const error = root.querySelector('[data-error]');
    const toast = root.querySelector('.toast');
    let latestSummary = '';

    function money(value) {
      return new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 }).format(Math.round(value));
    }

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function readNumber(input) {
      const value = Number(input.value);
      return Number.isFinite(value) ? value : NaN;
    }

    function drawChart(yearly) {
      if (!yearly.length) {
        chart.innerHTML = '';
        return;
      }
      const max = Math.max(...yearly.map((item) => item.balance), 1);
      const points = yearly
        .map((item, index) => {
          const x = 40 + (index / Math.max(1, yearly.length - 1)) * 560;
          const y = 180 - (item.balance / max) * 150;
          return `${x.toFixed(1)},${y.toFixed(1)}`;
        })
        .join(' ');
      const bars = yearly
        .map((item, index) => {
          const x = 36 + (index / Math.max(1, yearly.length)) * 560;
          const height = Math.max(2, (item.balance / max) * 150);
          return `<rect x="${x.toFixed(1)}" y="${(180 - height).toFixed(1)}" width="8" height="${height.toFixed(1)}" rx="4" fill="#cfe6e3" />`;
        })
        .join('');
      chart.innerHTML = `
        <line x1="40" y1="180" x2="600" y2="180" stroke="#9fb3c8" />
        <line x1="40" y1="30" x2="40" y2="180" stroke="#9fb3c8" />
        ${bars}
        <polyline points="${points}" fill="none" stroke="#0f8f8c" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
        <text x="40" y="205" fill="#657186" font-size="13">1</text>
        <text x="575" y="205" fill="#657186" font-size="13">${yearly.length}</text>
        <text x="48" y="26" fill="#657186" font-size="13">${money(max)}</text>
      `;
    }

    function calculate() {
      const principal = readNumber(inputs.principal);
      const monthly = readNumber(inputs.monthly);
      const rate = readNumber(inputs.rate) / 100;
      const years = Math.round(readNumber(inputs.years));
      const compounds = Number(inputs.compounding.value);
      if ([principal, monthly, rate, years].some((value) => !Number.isFinite(value) || value < 0) || years < 1) {
        setError(labels.invalidInput);
        return;
      }

      const monthlyRate = rate === 0 ? 0 : Math.pow(1 + rate / compounds, compounds / 12) - 1;
      let balance = principal;
      const yearly = [];
      for (let month = 1; month <= years * 12; month += 1) {
        balance = balance * (1 + monthlyRate) + monthly;
        if (month % 12 === 0) {
          yearly.push({ year: month / 12, balance });
        }
      }
      const contributed = principal + monthly * years * 12;
      const interest = balance - contributed;
      outputs.future.textContent = money(balance);
      outputs.contributed.textContent = money(contributed);
      outputs.interest.textContent = money(interest);
      latestSummary = [
        `${labels.futureValue}: ${money(balance)}`,
        `${labels.contributed}: ${money(contributed)}`,
        `${labels.interest}: ${money(interest)}`,
      ].join('\n');
      drawChart(yearly);
      setError('');
    }

    function showToast() {
      toast.hidden = false;
      window.setTimeout(() => {
        toast.hidden = true;
      }, 1500);
    }

    root.querySelector('[data-calculate]')?.addEventListener('click', calculate);
    root.querySelector('[data-copy]')?.addEventListener('click', async () => {
      if (!latestSummary) calculate();
      try {
        await navigator.clipboard.writeText(latestSummary);
        showToast();
      } catch {
        window.prompt(labels.copy, latestSummary);
      }
    });
    Object.values(inputs).forEach((input) => input.addEventListener('input', calculate));
    calculate();
  });
</script>
