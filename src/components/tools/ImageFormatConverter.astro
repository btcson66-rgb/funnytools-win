---
interface Props { labels: Record<string, string>; }
const { labels } = Astro.props;
---
<section class="tool-widget card" data-image-format data-labels={JSON.stringify(labels)}>
  <p class="note">{labels.localNote}</p><label><span>{labels.upload}</span><input data-file type="file" accept={labels.accept} /></label>
  <div class="form-grid two-col"><label><span>{labels.quality}</span><input data-quality type="range" min="40" max="100" value="85" /><output data-quality-value>85%</output></label>{labels.outputMime === 'image/jpeg' && <label><span>{labels.background}</span><input data-background type="color" value="#ffffff" /></label>}</div>
  <p class="form-error" data-error role="alert" hidden></p><div class="preview-grid"><figure><figcaption>{labels.source}</figcaption><img data-source hidden alt={labels.source} /></figure><figure><figcaption>{labels.output}</figcaption><img data-output hidden alt={labels.output} /></figure></div>
  <div class="stats-grid"><div><span>{labels.originalSize}</span><strong data-original>-</strong></div><div><span>{labels.outputSize}</span><strong data-size>-</strong></div></div>
  <div class="actions"><button class="btn go" type="button" data-download disabled>{labels.download}</button><button class="btn ghost" type="button" data-reset>{labels.reset}</button></div>
</section>
<style>.preview-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:16px 0}.preview-grid figure{min-height:220px;margin:0;padding:12px;display:grid;place-items:center;border:1px solid var(--line);border-radius:8px;background:var(--soft)}.preview-grid figcaption{justify-self:start;font-weight:800}.preview-grid img{max-width:100%;max-height:280px;object-fit:contain}@media(max-width:760px){.preview-grid{grid-template-columns:1fr}}</style>
<script>
  // @ts-nocheck -- DOM nodes are guaranteed by this component template.
  document.querySelectorAll('[data-image-format]').forEach((root)=>{const labels=JSON.parse(root.getAttribute('data-labels')||'{}');const fileInput=root.querySelector('[data-file]');const source=root.querySelector('[data-source]');const output=root.querySelector('[data-output]');const error=root.querySelector('[data-error]');const quality=root.querySelector('[data-quality]');const qValue=root.querySelector('[data-quality-value]');const download=root.querySelector('[data-download]');let sourceUrl='',outputUrl='',fileName='converted';const maxBytes=20*1024*1024,maxPixels=40000000;function revoke(){if(sourceUrl)URL.revokeObjectURL(sourceUrl);if(outputUrl)URL.revokeObjectURL(outputUrl);sourceUrl='';outputUrl='';}function size(n){return n>=1048576?`${(n/1048576).toFixed(2)} MB`:`${(n/1024).toFixed(1)} KB`;}async function run(){const file=fileInput.files?.[0];if(!file)return;error.hidden=true;if(file.size>maxBytes){error.textContent=labels.tooLarge;error.hidden=false;return;}revoke();const bitmap=await createImageBitmap(file);if(bitmap.width*bitmap.height>maxPixels){bitmap.close();error.textContent=labels.tooLarge;error.hidden=false;return;}sourceUrl=URL.createObjectURL(file);source.src=sourceUrl;source.hidden=false;const canvas=document.createElement('canvas');canvas.width=bitmap.width;canvas.height=bitmap.height;const ctx=canvas.getContext('2d');if(labels.outputMime==='image/jpeg'){ctx.fillStyle=root.querySelector('[data-background]')?.value||'#ffffff';ctx.fillRect(0,0,canvas.width,canvas.height);}ctx.drawImage(bitmap,0,0);bitmap.close();const blob=await new Promise(resolve=>canvas.toBlob(resolve,labels.outputMime,Number(quality.value)/100));if(!blob){error.textContent=labels.failed;error.hidden=false;return;}outputUrl=URL.createObjectURL(blob);output.src=outputUrl;output.hidden=false;root.querySelector('[data-original]').textContent=size(file.size);root.querySelector('[data-size]').textContent=size(blob.size);fileName=`${file.name.replace(/\.[^.]+$/,'')}.${labels.extension}`;download.disabled=false;}quality.addEventListener('input',()=>{qValue.textContent=`${quality.value}%`;run().catch(()=>{});});fileInput.addEventListener('change',()=>run().catch(()=>{error.textContent=labels.failed;error.hidden=false;}));root.querySelector('[data-background]')?.addEventListener('input',()=>run().catch(()=>{}));download.addEventListener('click',()=>{if(!outputUrl)return;const a=document.createElement('a');a.href=outputUrl;a.download=fileName;a.click();});root.querySelector('[data-reset]')?.addEventListener('click',()=>{revoke();fileInput.value='';source.hidden=true;output.hidden=true;download.disabled=true;});window.addEventListener('beforeunload',revoke);});
</script>
