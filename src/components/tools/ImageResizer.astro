---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card image-tool" data-image-resizer-tool data-labels={JSON.stringify(labels)}>
  <p class="note">{labels.localNote}</p>
  <label>
    <span>{labels.upload}</span>
    <input data-file type="file" accept="image/*" />
  </label>

  <div class="form-grid image-controls">
    <label>
      <span>{labels.width}</span>
      <input data-width type="number" min="1" max="8000" step="1" disabled />
    </label>
    <label>
      <span>{labels.height}</span>
      <input data-height type="number" min="1" max="8000" step="1" disabled />
    </label>
    <label class="check lock-row">
      <input data-lock type="checkbox" checked />
      <span>{labels.lockAspect}</span>
    </label>
  </div>

  <div class="preset-row" aria-label={labels.presets}>
    <span>{labels.presets}</span>
    <button class="btn ghost" type="button" data-preset="1080">1080</button>
    <button class="btn ghost" type="button" data-preset="800">800</button>
    <button class="btn ghost" type="button" data-preset="500">500</button>
  </div>

  <p class="form-error" data-error role="alert" hidden></p>

  <div class="preview-grid">
    <figure>
      <figcaption>{labels.sourcePreview}</figcaption>
      <img data-source-preview alt={labels.sourcePreview} hidden />
      <span data-source-empty>{labels.waiting}</span>
    </figure>
    <figure>
      <figcaption>{labels.outputPreview}</figcaption>
      <img data-output-preview alt={labels.outputPreview} hidden />
      <span data-output-empty>{labels.waiting}</span>
    </figure>
  </div>

  <div class="stats-grid image-stats" aria-live="polite">
    <div><span>{labels.originalSize}</span><strong data-original-size>-</strong></div>
    <div><span>{labels.dimensions}</span><strong data-dimensions>-</strong></div>
    <div><span>{labels.outputSize}</span><strong data-output-size>-</strong></div>
  </div>

  <div class="actions">
    <button class="btn go" type="button" data-download disabled>{labels.download}</button>
    <button class="btn ghost" type="button" data-reset>{labels.reset}</button>
  </div>
</section>

<style>
  .image-controls {
    margin: 16px 0 10px;
  }

  .lock-row {
    align-self: end;
  }

  .preset-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-bottom: 16px;
    color: var(--muted);
    font-weight: 800;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin: 18px 0;
  }

  figure {
    display: grid;
    min-height: 240px;
    margin: 0;
    padding: 12px;
    place-items: center;
    border: 1px solid #cfe6e3;
    border-radius: 8px;
    background: #f2fbfa;
  }

  figcaption {
    justify-self: start;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  figure img {
    display: block;
    max-height: 280px;
    border-radius: 8px;
    object-fit: contain;
  }

  figure span {
    color: var(--muted);
    font-weight: 800;
  }

  .image-stats {
    margin-bottom: 16px;
  }

  @media (max-width: 760px) {
    .preview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-image-resizer-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const fileInput = root.querySelector('[data-file]');
    const widthInput = root.querySelector('[data-width]');
    const heightInput = root.querySelector('[data-height]');
    const lockInput = root.querySelector('[data-lock]');
    const sourcePreview = root.querySelector('[data-source-preview]');
    const outputPreview = root.querySelector('[data-output-preview]');
    const sourceEmpty = root.querySelector('[data-source-empty]');
    const outputEmpty = root.querySelector('[data-output-empty]');
    const error = root.querySelector('[data-error]');
    const downloadButton = root.querySelector('[data-download]');
    const outputs = {
      original: root.querySelector('[data-original-size]'),
      dimensions: root.querySelector('[data-dimensions]'),
      output: root.querySelector('[data-output-size]'),
    };
    const maxBytes = 20 * 1024 * 1024;
    const maxPixels = 40_000_000;
    let state = null;
    let outputUrl = '';
    let renderTimer = null;
    let syncing = false;

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function formatSize(bytes) {
      if (!bytes) return '-';
      return bytes >= 1024 * 1024 ? `${(bytes / 1024 / 1024).toFixed(2)} MB` : `${(bytes / 1024).toFixed(1)} KB`;
    }

    function fileBaseName(name) {
      return name.replace(/\.[^.]+$/, '').replace(/[^\w-]+/g, '-').replace(/^-|-$/g, '') || 'image';
    }

    function revokeOutput() {
      if (outputUrl) URL.revokeObjectURL(outputUrl);
      outputUrl = '';
    }

    function clearOutput() {
      revokeOutput();
      outputPreview.hidden = true;
      outputPreview.removeAttribute('src');
      outputEmpty.hidden = false;
      downloadButton.disabled = true;
      outputs.dimensions.textContent = '-';
      outputs.output.textContent = '-';
    }

    let jobId = 0;

    function reset() {
      jobId += 1;
      state = null;
      fileInput.value = '';
      widthInput.value = '';
      heightInput.value = '';
      widthInput.disabled = true;
      heightInput.disabled = true;
      sourcePreview.hidden = true;
      sourcePreview.removeAttribute('src');
      sourceEmpty.hidden = false;
      outputs.original.textContent = '-';
      clearOutput();
      setError('');
    }

    function readImage(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onerror = reject;
        reader.onload = () => {
          const image = new Image();
          image.onload = () => resolve({ image, dataUrl: String(reader.result || '') });
          image.onerror = reject;
          image.src = String(reader.result || '');
        };
        reader.readAsDataURL(file);
      });
    }

    function outputType() {
      return ['image/jpeg', 'image/png', 'image/webp'].includes(state.file.type) ? state.file.type : 'image/png';
    }

    function extensionFor(type) {
      if (type === 'image/jpeg') return 'jpg';
      if (type === 'image/webp') return 'webp';
      return 'png';
    }

    function syncDimension(source) {
      if (!state || !lockInput.checked || syncing) return;
      syncing = true;
      if (source === widthInput) {
        heightInput.value = String(Math.max(1, Math.round(Number(widthInput.value) / state.aspect)));
      } else {
        widthInput.value = String(Math.max(1, Math.round(Number(heightInput.value) * state.aspect)));
      }
      syncing = false;
    }

    async function render() {
      if (!state) return;
      const myJob = jobId;
      const width = Math.round(Number(widthInput.value));
      const height = Math.round(Number(heightInput.value));
      if (!width || !height || width < 1 || height < 1 || width > 8000 || height > 8000) {
        setError(labels.dimensionError);
        clearOutput();
        return;
      }
      clearOutput();
      const canvas = document.createElement('canvas');
      canvas.width = width;
      canvas.height = height;
      const context = canvas.getContext('2d');
      context.drawImage(state.image, 0, 0, width, height);
      const type = outputType();
      const blob = await new Promise((resolve) => canvas.toBlob(resolve, type, 0.92));
      if (myJob !== jobId) return;
      if (!blob) {
        setError(labels.processError);
        return;
      }
      outputUrl = URL.createObjectURL(blob);
      outputPreview.src = outputUrl;
      outputPreview.hidden = false;
      outputEmpty.hidden = true;
      outputs.dimensions.textContent = `${width} x ${height}`;
      outputs.output.textContent = formatSize(blob.size);
      downloadButton.disabled = false;
      downloadButton.dataset.filename = `${state.baseName}-${width}x${height}.${extensionFor(type)}`;
      setError('');
    }

    function scheduleRender() {
      window.clearTimeout(renderTimer);
      renderTimer = window.setTimeout(render, 250);
    }

    async function handleFile() {
      const file = fileInput.files?.[0];
      reset();
      const myJob = jobId;
      if (!file) return;
      if (!file.type.startsWith('image/')) {
        setError(labels.invalidType);
        return;
      }
      if (file.size > maxBytes) {
        setError(labels.tooLarge);
        return;
      }
      try {
        const loaded = await readImage(file);
        if (myJob !== jobId) return;
        const width = loaded.image.naturalWidth;
        const height = loaded.image.naturalHeight;
        if (width * height > maxPixels) {
          setError(labels.tooLarge);
          return;
        }
        state = { file, image: loaded.image, baseName: fileBaseName(file.name), aspect: width / height };
        sourcePreview.src = loaded.dataUrl;
        sourcePreview.hidden = false;
        sourceEmpty.hidden = true;
        widthInput.value = String(width);
        heightInput.value = String(height);
        widthInput.disabled = false;
        heightInput.disabled = false;
        outputs.original.textContent = formatSize(file.size);
        await render();
      } catch {
        setError(labels.processError);
      }
    }

    fileInput.addEventListener('change', handleFile);
    widthInput.addEventListener('input', () => {
      syncDimension(widthInput);
      scheduleRender();
    });
    heightInput.addEventListener('input', () => {
      syncDimension(heightInput);
      scheduleRender();
    });
    root.querySelectorAll('[data-preset]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!state) return;
        widthInput.value = button.getAttribute('data-preset');
        syncDimension(widthInput);
        scheduleRender();
      });
    });
    root.querySelector('[data-reset]')?.addEventListener('click', reset);
    downloadButton.addEventListener('click', () => {
      if (!outputUrl) return;
      const anchor = document.createElement('a');
      anchor.href = outputUrl;
      anchor.download = downloadButton.dataset.filename || 'resized-image';
      anchor.click();
    });
    window.addEventListener('beforeunload', revokeOutput);
  });
</script>
