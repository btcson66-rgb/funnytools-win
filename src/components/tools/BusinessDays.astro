---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card" data-business-days-tool data-labels={JSON.stringify(labels)}>
  <div class="form-grid">
    <label>
      <span>{labels.startDate}</span>
      <input data-start type="date" />
    </label>
    <label>
      <span>{labels.endDate}</span>
      <input data-end type="date" />
    </label>
    <label class="check inline-toggle">
      <input data-include-end type="checkbox" checked />
      <span>{labels.includeEndDate}</span>
    </label>
  </div>
  <div class="option-row">
    <label class="check">
      <input data-skip-weekends type="checkbox" checked />
      <span>{labels.skipWeekends}</span>
    </label>
  </div>
  <label class="textarea-label compact-textarea">
    <span>{labels.holidays}</span>
    <textarea data-holidays rows="4" placeholder={labels.holidayPlaceholder}></textarea>
  </label>
  <div class="actions">
    <button class="btn go" type="button" data-calculate>{labels.calculate}</button>
    <button class="btn" type="button" data-copy>{labels.copyResult}</button>
    <button class="btn ghost" type="button" data-reset>{labels.reset}</button>
  </div>
  <p class="form-error" data-error role="alert" hidden></p>
  <div class="stats-grid business-stats" aria-live="polite">
    <div><span>{labels.businessDays}</span><strong data-business>0</strong></div>
    <div><span>{labels.totalCalendarDays}</span><strong data-total>0</strong></div>
    <div><span>{labels.weekendDays}</span><strong data-weekends>0</strong></div>
    <div><span>{labels.holidayDays}</span><strong data-holidays-count>0</strong></div>
    <div class="wide-stat"><span>{labels.countedRange}</span><strong data-range>-</strong></div>
  </div>
  <span class="toast" role="status" aria-live="polite" hidden>{labels.copied}</span>
</section>

<style>
  .inline-toggle {
    align-self: end;
    min-height: 48px;
  }

  .compact-textarea textarea {
    min-height: 118px;
  }

  .business-stats {
    margin-top: 18px;
  }

  .wide-stat {
    grid-column: span 2;
  }

  .business-stats strong {
    font-size: 1.25rem;
  }

  @media (max-width: 760px) {
    .wide-stat {
      grid-column: auto;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-business-days-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const startInput = root.querySelector('[data-start]');
    const endInput = root.querySelector('[data-end]');
    const includeEndInput = root.querySelector('[data-include-end]');
    const skipWeekendsInput = root.querySelector('[data-skip-weekends]');
    const holidaysInput = root.querySelector('[data-holidays]');
    const error = root.querySelector('[data-error]');
    const toast = root.querySelector('.toast');
    const outputs = {
      business: root.querySelector('[data-business]'),
      total: root.querySelector('[data-total]'),
      weekends: root.querySelector('[data-weekends]'),
      holidays: root.querySelector('[data-holidays-count]'),
      range: root.querySelector('[data-range]'),
    };
    let latestText = '';

    function localDate(value) {
      if (!value) return null;
      const [year, month, day] = value.split('-').map(Number);
      if (!year || !month || !day) return null;
      return new Date(year, month - 1, day);
    }

    function dateString(date) {
      const offset = date.getTimezoneOffset() * 60000;
      return new Date(date.getTime() - offset).toISOString().slice(0, 10);
    }

    function addDays(date, days) {
      const next = new Date(date);
      next.setDate(next.getDate() + days);
      return next;
    }

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function holidaySet() {
      return new Set(
        holidaysInput.value
          .split(/\r\n|\r|\n/)
          .map((line) => line.trim())
          .filter((line) => /^\d{4}-\d{2}-\d{2}$/.test(line)),
      );
    }

    function calculate() {
      const rawStart = localDate(startInput.value);
      const rawEnd = localDate(endInput.value);
      if (!rawStart || !rawEnd) {
        setError(labels.invalidDate);
        return;
      }
      let start = rawStart;
      let end = rawEnd;
      if (start > end) [start, end] = [end, start];
      const endExclusive = includeEndInput.checked ? addDays(end, 1) : end;
      const totalDays = Math.max(0, Math.round((endExclusive - start) / 86400000));
      const holidays = holidaySet();
      const skipWeekends = skipWeekendsInput.checked;
      let weekendDays = 0;
      let holidayDays = 0;
      let businessDays = 0;

      for (let index = 0; index < totalDays; index += 1) {
        const current = addDays(start, index);
        const isWeekend = current.getDay() === 0 || current.getDay() === 6;
        const isHoliday = holidays.has(dateString(current));
        if (isWeekend) weekendDays += 1;
        if (isHoliday && !(skipWeekends && isWeekend)) holidayDays += 1;
        if (!(skipWeekends && isWeekend) && !isHoliday) businessDays += 1;
      }

      outputs.business.textContent = `${businessDays} ${labels.days}`;
      outputs.total.textContent = `${totalDays} ${labels.days}`;
      outputs.weekends.textContent = `${weekendDays} ${labels.days}`;
      outputs.holidays.textContent = `${holidayDays} ${labels.days}`;
      outputs.range.textContent = `${dateString(start)} - ${dateString(end)}`;
      latestText = [
        `${labels.countedRange}: ${dateString(start)} - ${dateString(end)}`,
        `${labels.businessDays}: ${businessDays} ${labels.days}`,
        `${labels.totalCalendarDays}: ${totalDays} ${labels.days}`,
        `${labels.weekendDays}: ${weekendDays} ${labels.days}`,
        `${labels.holidayDays}: ${holidayDays} ${labels.days}`,
      ].join('\n');
      setError('');
    }

    function reset() {
      const today = new Date();
      startInput.value = dateString(today);
      endInput.value = dateString(addDays(today, 14));
      includeEndInput.checked = true;
      skipWeekendsInput.checked = true;
      holidaysInput.value = '';
      calculate();
    }

    function showToast() {
      toast.hidden = false;
      window.setTimeout(() => {
        toast.hidden = true;
      }, 1500);
    }

    root.querySelector('[data-calculate]')?.addEventListener('click', calculate);
    root.querySelector('[data-reset]')?.addEventListener('click', reset);
    root.querySelector('[data-copy]')?.addEventListener('click', async () => {
      if (!latestText) calculate();
      if (!latestText) return;
      try {
        await navigator.clipboard.writeText(latestText);
        showToast();
      } catch {
        window.prompt(labels.copyResult, latestText);
      }
    });
    [startInput, endInput, includeEndInput, skipWeekendsInput, holidaysInput].forEach((input) => input.addEventListener('input', calculate));
    [includeEndInput, skipWeekendsInput].forEach((input) => input.addEventListener('change', calculate));

    reset();
  });
</script>

