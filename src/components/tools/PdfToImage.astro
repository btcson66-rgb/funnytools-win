---
interface Props { labels: Record<string, string>; }
const { labels } = Astro.props;
---
<section class="tool-widget card" data-pdf-image data-labels={JSON.stringify(labels)}><p class="note">{labels.localNote}</p><label><span>{labels.upload}</span><input data-file type="file" accept="application/pdf,.pdf" /></label><div class="form-grid two-col"><label><span>{labels.format}</span><select data-format><option value="image/png">PNG</option><option value="image/jpeg">JPG</option></select></label><label><span>{labels.scale}</span><select data-scale><option value="1">1×</option><option value="1.5" selected>1.5×</option><option value="2">2×</option></select></label></div><p class="form-error" data-error hidden role="alert"></p><p data-status aria-live="polite"></p><div data-results class="image-results"></div></section>
<style>.image-results{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px}.image-results figure{margin:0;padding:10px;border:1px solid var(--line);border-radius:8px}.image-results img{width:100%;height:auto}.image-results a{display:inline-block;margin-top:8px}</style>
<script>
  // @ts-nocheck -- DOM nodes are guaranteed by this component template.
  document.querySelectorAll('[data-pdf-image]').forEach((root)=>{const labels=JSON.parse(root.getAttribute('data-labels')||'{}');const input=root.querySelector('[data-file]');const results=root.querySelector('[data-results]');const error=root.querySelector('[data-error]');const status=root.querySelector('[data-status]');let urls=[];function clear(){urls.forEach(URL.revokeObjectURL);urls=[];results.innerHTML='';}input.addEventListener('change',async()=>{clear();try{const file=input.files?.[0];if(!file)return;if(file.size>25*1024*1024)throw new Error(labels.tooLarge);const pdfjs=await import('pdfjs-dist');pdfjs.GlobalWorkerOptions.workerSrc=new URL('pdfjs-dist/build/pdf.worker.min.mjs',import.meta.url).toString();const pdf=await pdfjs.getDocument({data:await file.arrayBuffer()}).promise;if(pdf.numPages>20)throw new Error(labels.tooMany);const scale=Number(root.querySelector('[data-scale]').value);const mime=root.querySelector('[data-format]').value;for(let n=1;n<=pdf.numPages;n++){status.textContent=labels.processing.replace('{page}',String(n)).replace('{total}',String(pdf.numPages));const page=await pdf.getPage(n);const viewport=page.getViewport({scale});if(viewport.width*viewport.height>16000000)throw new Error(labels.tooLarge);const canvas=document.createElement('canvas');canvas.width=Math.ceil(viewport.width);canvas.height=Math.ceil(viewport.height);await page.render({canvasContext:canvas.getContext('2d'),viewport}).promise;const blob=await new Promise(resolve=>canvas.toBlob(resolve,mime,mime==='image/jpeg'?0.9:undefined));const url=URL.createObjectURL(blob);urls.push(url);const figure=document.createElement('figure');const img=document.createElement('img');img.src=url;img.alt=labels.page.replace('{page}',String(n));const link=document.createElement('a');link.className='btn';link.href=url;link.download=`page-${n}.${mime==='image/png'?'png':'jpg'}`;link.textContent=labels.downloadPage.replace('{page}',String(n));figure.append(img,link);results.append(figure);}status.textContent=labels.done;error.hidden=true;}catch(caught){error.textContent=caught instanceof Error?caught.message:labels.failed;error.hidden=false;status.textContent='';}});window.addEventListener('beforeunload',clear);});
</script>
