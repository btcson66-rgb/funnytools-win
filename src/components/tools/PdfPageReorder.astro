---
interface Props { labels: Record<string, string>; }
const { labels } = Astro.props;
---
<section class="tool-widget card" data-pdf-reorder data-labels={JSON.stringify(labels)}><p class="note">{labels.localNote}</p><label><span>{labels.upload}</span><input data-file type="file" accept="application/pdf,.pdf" /></label><p class="form-error" data-error hidden role="alert"></p><div data-pages class="page-list"></div><div class="actions"><button class="btn go" type="button" data-download disabled>{labels.download}</button><button class="btn ghost" type="button" data-reset>{labels.reset}</button></div></section>
<style>.page-list{display:grid;gap:8px;margin:16px 0}.page-row{display:flex;flex-wrap:wrap;gap:10px;align-items:center;justify-content:space-between;padding:10px;border:1px solid var(--line);border-radius:8px}.page-row strong{min-width:0;overflow-wrap:anywhere}.page-row .actions{margin:0}@media(max-width:760px){.page-row{align-items:flex-start;flex-direction:column}.page-row .actions{width:100%}.page-row .btn{flex:1 1 0;min-width:0}}</style>
<script>
  // @ts-nocheck -- DOM nodes are guaranteed by this component template.
  document.querySelectorAll('[data-pdf-reorder]').forEach((root)=>{const labels=JSON.parse(root.getAttribute('data-labels')||'{}');const fileInput=root.querySelector('[data-file]');const list=root.querySelector('[data-pages]');const error=root.querySelector('[data-error]');const download=root.querySelector('[data-download]');let doc=null,order=[];function render(){list.innerHTML='';order.forEach((page,index)=>{const row=document.createElement('div');row.className='page-row';const title=document.createElement('strong');title.textContent=labels.page.replace('{page}',String(page+1));const actions=document.createElement('div');actions.className='actions';[['↑',-1],['↓',1]].forEach(([text,delta])=>{const b=document.createElement('button');b.className='btn ghost';b.type='button';b.textContent=text;b.disabled=index+delta<0||index+delta>=order.length;b.addEventListener('click',()=>{const target=index+delta;[order[index],order[target]]=[order[target],order[index]];render();});actions.append(b);});row.append(title,actions);list.append(row);});}fileInput.addEventListener('change',async()=>{try{const file=fileInput.files?.[0];if(!file)return;if(file.size>40*1024*1024)throw new Error(labels.tooLarge);const {PDFDocument}=await import('pdf-lib');doc=await PDFDocument.load(await file.arrayBuffer());order=Array.from({length:doc.getPageCount()},(_,i)=>i);render();download.disabled=false;error.hidden=true;}catch(caught){error.textContent=caught instanceof Error?caught.message:labels.failed;error.hidden=false;}});download.addEventListener('click',async()=>{if(!doc)return;const {PDFDocument}=await import('pdf-lib');const output=await PDFDocument.create();const pages=await output.copyPages(doc,order);pages.forEach(page=>output.addPage(page));const bytes=await output.save();const url=URL.createObjectURL(new Blob([bytes],{type:'application/pdf'}));const a=document.createElement('a');a.href=url;a.download='reordered.pdf';a.click();setTimeout(()=>URL.revokeObjectURL(url),1000);});root.querySelector('[data-reset]')?.addEventListener('click',()=>{doc=null;order=[];fileInput.value='';download.disabled=true;render();});});
</script>
