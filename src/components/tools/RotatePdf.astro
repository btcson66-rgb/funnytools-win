---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card pdf-tool" data-rotate-pdf-tool data-labels={JSON.stringify(labels)}>
  <p class="note">{labels.localNote}</p>
  <label>
    <span>{labels.upload}</span>
    <input data-file type="file" accept="application/pdf" />
  </label>

  <div class="form-grid pdf-options">
    <label>
      <span>{labels.scope}</span>
      <select data-scope>
        <option value="all">{labels.allPages}</option>
        <option value="custom">{labels.customPages}</option>
      </select>
    </label>
    <label>
      <span>{labels.angle}</span>
      <select data-angle>
        <option value="90">{labels.deg90}</option>
        <option value="180">{labels.deg180}</option>
        <option value="270">{labels.deg270}</option>
      </select>
    </label>
  </div>

  <label>
    <span>{labels.pagesLabel}</span>
    <input data-ranges type="text" placeholder={labels.rangesPlaceholder} />
  </label>

  <p class="form-error" data-error role="alert" hidden></p>
  <p class="toast" data-status role="status" aria-live="polite" hidden></p>

  <div class="actions">
    <button class="btn" type="button" data-analyze>{labels.analyze}</button>
    <button class="btn go" type="button" data-rotate>{labels.rotate}</button>
    <button class="btn ghost" type="button" data-reset>{labels.reset}</button>
  </div>
</section>

<style>
  select {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--card);
    color: var(--ink);
    padding: 10px 12px;
    font: inherit;
  }

  .pdf-tool {
    display: grid;
    gap: 16px;
  }

  .pdf-options {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (max-width: 760px) {
    .pdf-options {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-rotate-pdf-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const fileInput = root.querySelector('[data-file]');
    const scopeInput = root.querySelector('[data-scope]');
    const angleInput = root.querySelector('[data-angle]');
    const rangesInput = root.querySelector('[data-ranges]');
    const error = root.querySelector('[data-error]');
    const status = root.querySelector('[data-status]');
    const actionButtons = root.querySelectorAll('button');
    let pdfLibPromise = null;
    let file = null;
    let pageCount = 0;

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function setStatus(message) {
      status.textContent = message;
      status.hidden = !message;
    }

    function setBusy(isBusy) {
      actionButtons.forEach((button) => {
        if (button.matches('[data-reset]')) return;
        button.disabled = isBusy;
      });
      if (isBusy) setStatus(labels.processing);
    }

    function isPdf(nextFile) {
      return nextFile.type === 'application/pdf' || /\.pdf$/i.test(nextFile.name);
    }

    function safeBaseName(name) {
      return name.replace(/\.[^.]+$/, '').replace(/[^\w-]+/g, '-').replace(/^-|-$/g, '') || 'rotated';
    }

    async function loadPdfLib() {
      if (!pdfLibPromise) {
        pdfLibPromise = (async () => {
          const mod = await import('pdf-lib');
          const { PDFDocument, degrees } = mod;
          return { PDFDocument, degrees };
        })();
      }
      return pdfLibPromise;
    }

    async function loadDocument() {
      if (!file) throw new Error('missing-file');
      const { PDFDocument } = await loadPdfLib();
      const bytes = await file.arrayBuffer();
      const doc = await PDFDocument.load(bytes);
      pageCount = doc.getPageCount();
      return doc;
    }

    function clamp(value, min, max) {
      return Math.min(Math.max(value, min), max);
    }

    function parsePageSet(input, total) {
      const text = input.trim();
      if (!text) throw new Error(labels.emptyRange);
      const tokens = text.split(',');
      const pages = new Set();
      for (const token of tokens) {
        const part = token.trim();
        const match = part.match(/^(\d+)(?:\s*-\s*(\d+))?$/);
        if (!match) throw new Error(labels.invalidRange);
        const rawStart = Number(match[1]);
        const rawEnd = match[2] ? Number(match[2]) : rawStart;
        if (rawStart < 1 || rawEnd < 1 || rawStart > rawEnd || rawEnd > total) throw new Error(labels.invalidRange);
        const start = clamp(rawStart, 1, total);
        const end = clamp(rawEnd, 1, total);
        for (let page = start; page <= end; page += 1) {
          pages.add(page - 1);
        }
      }
      if (!pages.size) throw new Error(labels.emptyRange);
      return pages;
    }

    async function analyze() {
      if (!file) {
        setError(labels.noFile);
        return false;
      }
      try {
        setBusy(true);
        setError('');
        await loadDocument();
        setStatus(labels.pageCount.replace('{count}', String(pageCount)));
        return true;
      } catch {
        setError(labels.loadError);
        return false;
      } finally {
        setBusy(false);
      }
    }

    function downloadPdf(bytes, filename) {
      const blob = new Blob([bytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = url;
      anchor.download = filename;
      anchor.click();
      window.setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    async function rotatePdf() {
      if (!file) {
        setError(labels.noFile);
        return;
      }
      try {
        setBusy(true);
        setError('');
        const { degrees } = await loadPdfLib();
        const doc = await loadDocument();
        const pages = doc.getPages();
        const selected = scopeInput.value === 'all'
          ? new Set(pages.map((_, index) => index))
          : parsePageSet(rangesInput.value, pageCount);
        const angle = Number(angleInput.value);
        pages.forEach((page, index) => {
          if (!selected.has(index)) return;
          const current = page.getRotation().angle || 0;
          page.setRotation(degrees((current + angle) % 360));
        });
        const bytes = await doc.save();
        downloadPdf(bytes, `${safeBaseName(file.name)}-rotated.pdf`);
        setStatus(labels.downloaded);
      } catch (err) {
        const rangeMessage = err instanceof Error && (err.message === labels.emptyRange || err.message === labels.invalidRange);
        setError(rangeMessage ? err.message : labels.rotateError);
      } finally {
        setBusy(false);
      }
    }

    function reset() {
      file = null;
      pageCount = 0;
      fileInput.value = '';
      rangesInput.value = '';
      setError('');
      setStatus('');
    }

    fileInput.addEventListener('change', () => {
      setError('');
      setStatus('');
      pageCount = 0;
      file = fileInput.files?.[0] || null;
      if (file && !isPdf(file)) {
        file = null;
        fileInput.value = '';
        setError(labels.pdfOnly);
      }
    });

    root.querySelector('[data-analyze]')?.addEventListener('click', analyze);
    root.querySelector('[data-rotate]')?.addEventListener('click', rotatePdf);
    root.querySelector('[data-reset]')?.addEventListener('click', reset);
  });
</script>
