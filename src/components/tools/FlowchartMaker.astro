---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card flowchart-tool" data-flowchart-tool data-labels={JSON.stringify(labels)}>
  <div class="flow-toolbar" role="toolbar" aria-label={labels.toolbar}>
    <button class="btn ghost is-active" type="button" data-mode="select">{labels.selectMove}</button>
    <button class="btn ghost" type="button" data-mode="connect">{labels.connect}</button>
    <button class="btn" type="button" data-add="process">{labels.addProcess}</button>
    <button class="btn" type="button" data-add="decision">{labels.addDecision}</button>
    <button class="btn ghost" type="button" data-delete>{labels.deleteSelected}</button>
    <button class="btn" type="button" data-clear>{labels.clearAll}</button>
    <button class="btn go" type="button" data-download>{labels.exportPng}</button>
  </div>

  <div class="flow-canvas-wrap">
    <canvas data-canvas width="1000" height="620" aria-label={labels.canvasLabel}></canvas>
  </div>

  <p class="flow-status" data-status aria-live="polite">{labels.nothingSelected}</p>
</section>

<style>
  .flow-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-bottom: 16px;
  }

  .flow-toolbar .is-active {
    border-color: rgba(15, 143, 140, 0.42);
    background: #eef8f7;
    color: #08736f;
  }

  .flow-canvas-wrap {
    padding: 10px;
    border: 1px solid #cfe6e3;
    border-radius: 8px;
    background: #f2fbfa;
  }

  canvas {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    touch-action: none;
  }

  .flow-status {
    margin: 12px 0 0;
    color: var(--muted);
    font-weight: 800;
  }
</style>

<script>
  document.querySelectorAll('[data-flowchart-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const canvas = root.querySelector('[data-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const context = canvas.getContext('2d');
    if (!context) return;

    const status = root.querySelector('[data-status]');
    const modeButtons = Array.from(root.querySelectorAll('[data-mode]'));
    const nodes = [];
    const edges = [];
    const colors = {
      nodeFill: '#ffffff',
      nodeStroke: '#0f8f8c',
      decisionStroke: '#3e63dd',
      selected: '#f26b4f',
      edge: '#18212f',
      muted: '#657186',
    };
    let mode = 'select';
    let selectedNodeId = '';
    let selectedEdgeId = '';
    let connectSourceId = '';
    let dragState = null;
    let nextId = 1;

    function canvasPoint(event) {
      const rect = canvas.getBoundingClientRect();
      return {
        x: ((event.clientX - rect.left) * canvas.width) / rect.width,
        y: ((event.clientY - rect.top) * canvas.height) / rect.height,
      };
    }

    function nodeCenter(node) {
      return { x: node.x, y: node.y };
    }

    function findNode(id) {
      return nodes.find((node) => node.id === id);
    }

    function setStatus(message) {
      status.textContent = message;
    }

    function setMode(nextMode) {
      mode = nextMode;
      connectSourceId = '';
      modeButtons.forEach((button) => {
        button.classList.toggle('is-active', button.getAttribute('data-mode') === mode);
      });
      setStatus(mode === 'connect' ? labels.connectFirst : labels.nothingSelected);
      render();
    }

    function hitNode(point) {
      for (let index = nodes.length - 1; index >= 0; index -= 1) {
        const node = nodes[index];
        const dx = point.x - node.x;
        const dy = point.y - node.y;
        if (node.type === 'decision') {
          if (Math.abs(dx) / (node.w / 2) + Math.abs(dy) / (node.h / 2) <= 1) return node;
        } else if (Math.abs(dx) <= node.w / 2 && Math.abs(dy) <= node.h / 2) {
          return node;
        }
      }
      return null;
    }

    function distanceToSegment(point, start, end) {
      const dx = end.x - start.x;
      const dy = end.y - start.y;
      const lengthSquared = dx * dx + dy * dy;
      if (!lengthSquared) return Math.hypot(point.x - start.x, point.y - start.y);
      const t = Math.max(0, Math.min(1, ((point.x - start.x) * dx + (point.y - start.y) * dy) / lengthSquared));
      const projection = { x: start.x + t * dx, y: start.y + t * dy };
      return Math.hypot(point.x - projection.x, point.y - projection.y);
    }

    function boundaryPoint(node, toward) {
      const dx = toward.x - node.x;
      const dy = toward.y - node.y;
      if (!dx && !dy) return { x: node.x, y: node.y };
      let factor;
      if (node.type === 'decision') {
        factor = 1 / (Math.abs(dx) / (node.w / 2) + Math.abs(dy) / (node.h / 2));
      } else {
        factor = 1 / Math.max(Math.abs(dx) / (node.w / 2), Math.abs(dy) / (node.h / 2));
      }
      return { x: node.x + dx * factor, y: node.y + dy * factor };
    }

    function edgePoints(edge) {
      const from = findNode(edge.from);
      const to = findNode(edge.to);
      if (!from || !to) return null;
      const fromCenter = nodeCenter(from);
      const toCenter = nodeCenter(to);
      return {
        start: boundaryPoint(from, toCenter),
        end: boundaryPoint(to, fromCenter),
      };
    }

    function hitEdge(point) {
      for (let index = edges.length - 1; index >= 0; index -= 1) {
        const points = edgePoints(edges[index]);
        if (points && distanceToSegment(point, points.start, points.end) <= 10) return edges[index];
      }
      return null;
    }

    function selectNode(node) {
      selectedNodeId = node?.id || '';
      selectedEdgeId = '';
      setStatus(selectedNodeId ? labels.selectedNode : labels.nothingSelected);
      render();
    }

    function selectEdge(edge) {
      selectedEdgeId = edge?.id || '';
      selectedNodeId = '';
      setStatus(selectedEdgeId ? labels.selectedEdge : labels.nothingSelected);
      render();
    }

    function addNode(type) {
      const offset = nodes.length * 26;
      nodes.push({
        id: `node-${nextId}`,
        type,
        x: 230 + (offset % 360),
        y: 160 + (offset % 260),
        w: type === 'decision' ? 170 : 190,
        h: type === 'decision' ? 110 : 86,
        text: type === 'decision' ? labels.decisionText : labels.processText,
      });
      nextId += 1;
      selectNode(nodes[nodes.length - 1]);
    }

    function deleteSelected() {
      if (selectedNodeId) {
        const nodeIndex = nodes.findIndex((node) => node.id === selectedNodeId);
        if (nodeIndex >= 0) nodes.splice(nodeIndex, 1);
        for (let index = edges.length - 1; index >= 0; index -= 1) {
          if (edges[index].from === selectedNodeId || edges[index].to === selectedNodeId) edges.splice(index, 1);
        }
        selectedNodeId = '';
      } else if (selectedEdgeId) {
        const edgeIndex = edges.findIndex((edge) => edge.id === selectedEdgeId);
        if (edgeIndex >= 0) edges.splice(edgeIndex, 1);
        selectedEdgeId = '';
      }
      setStatus(labels.nothingSelected);
      render();
    }

    function clearAll() {
      if (!window.confirm(labels.confirmClear)) return;
      nodes.splice(0, nodes.length);
      edges.splice(0, edges.length);
      selectedNodeId = '';
      selectedEdgeId = '';
      connectSourceId = '';
      setStatus(labels.nothingSelected);
      render();
    }

    function wrapLines(text, maxWidth) {
      const words = String(text || '').split(/\s+/).filter(Boolean);
      const source = words.length ? words : String(text || '').split('');
      const lines = [];
      let line = '';
      source.forEach((word) => {
        const nextLine = line ? `${line} ${word}` : word;
        if (context.measureText(nextLine).width <= maxWidth || !line) {
          line = nextLine;
        } else {
          lines.push(line);
          line = word;
        }
      });
      if (line) lines.push(line);
      return lines.slice(0, 3);
    }

    function drawArrow(start, end, selected) {
      const angle = Math.atan2(end.y - start.y, end.x - start.x);
      context.save();
      context.strokeStyle = selected ? colors.selected : colors.edge;
      context.fillStyle = selected ? colors.selected : colors.edge;
      context.lineWidth = selected ? 3 : 2;
      context.beginPath();
      context.moveTo(start.x, start.y);
      context.lineTo(end.x, end.y);
      context.stroke();
      context.beginPath();
      context.moveTo(end.x, end.y);
      context.lineTo(end.x - Math.cos(angle - Math.PI / 7) * 15, end.y - Math.sin(angle - Math.PI / 7) * 15);
      context.lineTo(end.x - Math.cos(angle + Math.PI / 7) * 15, end.y - Math.sin(angle + Math.PI / 7) * 15);
      context.closePath();
      context.fill();
      context.restore();
    }

    function drawNode(node, selected, exporting) {
      context.save();
      context.fillStyle = colors.nodeFill;
      context.strokeStyle = selected && !exporting ? colors.selected : node.type === 'decision' ? colors.decisionStroke : colors.nodeStroke;
      context.lineWidth = selected && !exporting ? 4 : 2;
      context.beginPath();
      if (node.type === 'decision') {
        context.moveTo(node.x, node.y - node.h / 2);
        context.lineTo(node.x + node.w / 2, node.y);
        context.lineTo(node.x, node.y + node.h / 2);
        context.lineTo(node.x - node.w / 2, node.y);
        context.closePath();
      } else {
        context.roundRect(node.x - node.w / 2, node.y - node.h / 2, node.w, node.h, 10);
      }
      context.fill();
      context.stroke();
      context.fillStyle = '#18212f';
      context.font = '800 18px sans-serif';
      context.textAlign = 'center';
      context.textBaseline = 'middle';
      const lines = wrapLines(node.text, node.w * 0.68);
      const lineHeight = 22;
      const startY = node.y - ((lines.length - 1) * lineHeight) / 2;
      lines.forEach((line, index) => {
        context.fillText(line, node.x, startY + index * lineHeight);
      });
      context.restore();
    }

    function render(exporting = false) {
      context.clearRect(0, 0, canvas.width, canvas.height);
      context.fillStyle = '#ffffff';
      context.fillRect(0, 0, canvas.width, canvas.height);
      context.strokeStyle = '#eef2f6';
      context.lineWidth = 1;
      for (let x = 40; x < canvas.width; x += 40) {
        context.beginPath();
        context.moveTo(x, 0);
        context.lineTo(x, canvas.height);
        context.stroke();
      }
      for (let y = 40; y < canvas.height; y += 40) {
        context.beginPath();
        context.moveTo(0, y);
        context.lineTo(canvas.width, y);
        context.stroke();
      }

      edges.forEach((edge) => {
        const points = edgePoints(edge);
        if (points) drawArrow(points.start, points.end, edge.id === selectedEdgeId && !exporting);
      });
      nodes.forEach((node) => drawNode(node, node.id === selectedNodeId, exporting));

      if (connectSourceId && !exporting) {
        const source = findNode(connectSourceId);
        if (source) {
          context.save();
          context.strokeStyle = colors.selected;
          context.setLineDash([6, 6]);
          context.lineWidth = 3;
          context.beginPath();
          context.arc(source.x, source.y, Math.max(source.w, source.h) / 2 + 10, 0, Math.PI * 2);
          context.stroke();
          context.restore();
        }
      }
    }

    function handlePointerDown(event) {
      event.preventDefault();
      const point = canvasPoint(event);
      const node = hitNode(point);

      if (mode === 'connect') {
        if (!node) return;
        if (!connectSourceId) {
          connectSourceId = node.id;
          selectNode(node);
          setStatus(labels.connectSecond);
          render();
          return;
        }
        if (connectSourceId !== node.id) {
          edges.push({ id: `edge-${nextId}`, from: connectSourceId, to: node.id });
          nextId += 1;
          selectedNodeId = '';
          selectedEdgeId = edges[edges.length - 1].id;
        }
        connectSourceId = '';
        setStatus(labels.selectedEdge);
        render();
        return;
      }

      if (node) {
        selectNode(node);
        dragState = { id: node.id, dx: point.x - node.x, dy: point.y - node.y };
        canvas.setPointerCapture(event.pointerId);
        return;
      }

      const edge = hitEdge(point);
      if (edge) {
        selectEdge(edge);
        return;
      }

      selectNode(null);
    }

    function handlePointerMove(event) {
      if (!dragState) return;
      event.preventDefault();
      const node = findNode(dragState.id);
      if (!node) return;
      const point = canvasPoint(event);
      node.x = Math.max(node.w / 2 + 10, Math.min(canvas.width - node.w / 2 - 10, point.x - dragState.dx));
      node.y = Math.max(node.h / 2 + 10, Math.min(canvas.height - node.h / 2 - 10, point.y - dragState.dy));
      render();
    }

    function handlePointerUp(event) {
      if (!dragState) return;
      dragState = null;
      try {
        canvas.releasePointerCapture(event.pointerId);
      } catch {
        // Pointer capture may already be released by the browser.
      }
    }

    function editNode(event) {
      const node = hitNode(canvasPoint(event));
      if (!node) return;
      const value = window.prompt(labels.editPrompt, node.text);
      if (value === null) return;
      node.text = value.trim() || node.text;
      selectNode(node);
    }

    function download() {
      render(true);
      const anchor = document.createElement('a');
      anchor.href = canvas.toDataURL('image/png');
      anchor.download = 'flowchart.png';
      anchor.click();
      render(false);
    }

    modeButtons.forEach((button) => {
      button.addEventListener('click', () => setMode(button.getAttribute('data-mode') || 'select'));
    });
    root.querySelector('[data-add="process"]')?.addEventListener('click', () => addNode('process'));
    root.querySelector('[data-add="decision"]')?.addEventListener('click', () => addNode('decision'));
    root.querySelector('[data-delete]')?.addEventListener('click', deleteSelected);
    root.querySelector('[data-clear]')?.addEventListener('click', clearAll);
    root.querySelector('[data-download]')?.addEventListener('click', download);
    canvas.addEventListener('pointerdown', handlePointerDown);
    canvas.addEventListener('pointermove', handlePointerMove);
    canvas.addEventListener('pointerup', handlePointerUp);
    canvas.addEventListener('pointercancel', handlePointerUp);
    canvas.addEventListener('dblclick', editNode);

    addNode('process');
    addNode('decision');
    edges.push({ id: `edge-${nextId}`, from: nodes[0].id, to: nodes[1].id });
    nextId += 1;
    selectedNodeId = '';
    selectedEdgeId = '';
    setStatus(labels.nothingSelected);
    render();
  });
</script>
