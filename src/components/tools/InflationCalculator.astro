---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card" data-inflation-tool data-labels={JSON.stringify(labels)}>
  <div class="form-grid">
    <label>
      <span>{labels.amount}</span>
      <input data-amount type="number" step="100" value="10000" />
    </label>
    <label>
      <span>{labels.annualRate}</span>
      <input data-rate type="number" step="0.1" value="3" />
    </label>
    <label>
      <span>{labels.years}</span>
      <input data-years type="number" min="0" step="1" value="5" />
    </label>
    <label>
      <span>{labels.mode}</span>
      <select data-mode>
        <option value="futureCost">{labels.futureCost}</option>
        <option value="futureBuyingPower">{labels.futureBuyingPower}</option>
        <option value="pastEquivalent">{labels.pastEquivalent}</option>
      </select>
    </label>
  </div>

  <div class="actions">
    <button class="btn go" type="button" data-calculate>{labels.calculate}</button>
    <button class="btn" type="button" data-copy>{labels.copy}</button>
    <button class="btn ghost" type="button" data-reset>{labels.reset}</button>
  </div>

  <p class="form-error" data-error role="alert" hidden></p>
  <div class="stats-grid finance-stats" aria-live="polite">
    <div><span>{labels.adjustedAmount}</span><strong data-adjusted>-</strong></div>
    <div><span>{labels.change}</span><strong data-change>-</strong></div>
    <div><span>{labels.formula}</span><strong data-formula>-</strong></div>
  </div>
  <span class="toast" role="status" aria-live="polite" hidden>{labels.copied}</span>
</section>

<style>
  select {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--card);
    color: var(--ink);
    padding: 10px 12px;
    font: inherit;
  }

  .actions {
    margin: 16px 0;
  }

  .finance-stats strong {
    font-size: 1.25rem;
  }
</style>

<script>
  document.querySelectorAll('[data-inflation-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const amountInput = root.querySelector('[data-amount]');
    const rateInput = root.querySelector('[data-rate]');
    const yearsInput = root.querySelector('[data-years]');
    const modeInput = root.querySelector('[data-mode]');
    const outputs = {
      adjusted: root.querySelector('[data-adjusted]'),
      change: root.querySelector('[data-change]'),
      formula: root.querySelector('[data-formula]'),
    };
    const error = root.querySelector('[data-error]');
    const toast = root.querySelector('.toast');
    let latestText = '';

    function money(value) {
      return new Intl.NumberFormat(undefined, { maximumFractionDigits: 2 }).format(value);
    }

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function calculate() {
      const amount = Number(amountInput.value);
      const rate = Number(rateInput.value) / 100;
      const years = Number(yearsInput.value);
      if (![amount, rate, years].every(Number.isFinite) || years < 0 || rate <= -1) {
        setError(labels.invalidInput);
        return;
      }
      const factor = Math.pow(1 + rate, years);
      const mode = modeInput.value;
      let adjusted = amount * factor;
      let formula = 'amount × (1 + rate)^years';
      if (mode === 'futureBuyingPower') {
        adjusted = amount / factor;
        formula = 'amount ÷ (1 + rate)^years';
      }
      if (mode === 'pastEquivalent') {
        adjusted = amount / factor;
        formula = 'amount ÷ (1 + rate)^years';
      }
      const change = adjusted - amount;
      outputs.adjusted.textContent = money(adjusted);
      outputs.change.textContent = money(change);
      outputs.formula.textContent = formula;
      latestText = [
        `${labels.mode}: ${labels[mode]}`,
        `${labels.adjustedAmount}: ${money(adjusted)}`,
        `${labels.change}: ${money(change)}`,
        `${labels.formula}: ${formula}`,
      ].join('\n');
      setError('');
    }

    function reset() {
      amountInput.value = '10000';
      rateInput.value = '3';
      yearsInput.value = '5';
      modeInput.value = 'futureCost';
      calculate();
    }

    function showToast() {
      toast.hidden = false;
      window.setTimeout(() => {
        toast.hidden = true;
      }, 1500);
    }

    root.querySelector('[data-calculate]')?.addEventListener('click', calculate);
    root.querySelector('[data-reset]')?.addEventListener('click', reset);
    root.querySelector('[data-copy]')?.addEventListener('click', async () => {
      if (!latestText) calculate();
      try {
        await navigator.clipboard.writeText(latestText);
        showToast();
      } catch {
        window.prompt(labels.copy, latestText);
      }
    });
    [amountInput, rateInput, yearsInput, modeInput].forEach((input) => {
      input.addEventListener('input', calculate);
      input.addEventListener('change', calculate);
    });
    calculate();
  });
</script>

