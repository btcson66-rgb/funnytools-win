---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card" data-password-tool data-labels={JSON.stringify(labels)}>
  <label class="range-label">
    <span><span>{labels.length}</span>: <strong data-length-value>16</strong></span>
    <input data-length type="range" min="4" max="64" value="16" />
  </label>
  <div class="option-row password-options">
    <label class="check">
      <input data-class="uppercase" type="checkbox" checked />
      <span>{labels.uppercase}</span>
    </label>
    <label class="check">
      <input data-class="lowercase" type="checkbox" checked />
      <span>{labels.lowercase}</span>
    </label>
    <label class="check">
      <input data-class="numbers" type="checkbox" checked />
      <span>{labels.numbers}</span>
    </label>
    <label class="check">
      <input data-class="symbols" type="checkbox" checked />
      <span>{labels.symbols}</span>
    </label>
    <label class="check">
      <input data-ambiguous type="checkbox" />
      <span>{labels.excludeAmbiguous}</span>
    </label>
  </div>
  <p class="form-error" data-error role="alert" hidden></p>
  <div class="bigresult password-result" aria-live="polite">
    <span class="result-label">{labels.result}</span>
    <output data-output></output>
  </div>
  <div class="strength-row" aria-live="polite">
    <span>{labels.strength}</span>
    <strong data-strength></strong>
    <span class="strength-track"><span data-strength-bar></span></span>
  </div>
  <div class="actions">
    <button class="btn go" type="button" data-generate>{labels.generate}</button>
    <button class="btn ghost" type="button" data-copy>{labels.copy}</button>
  </div>
  <span class="toast" role="status" aria-live="polite" hidden>{labels.copied}</span>
</section>

<style>
  .range-label {
    margin-bottom: 12px;
  }

  .password-options {
    margin-top: 10px;
  }

  .password-result output {
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: clamp(1.35rem, 5vw, 2.15rem);
  }

  .strength-row {
    display: grid;
    grid-template-columns: auto auto minmax(120px, 1fr);
    gap: 10px;
    align-items: center;
    margin: 14px 0;
    color: var(--muted);
    font-weight: 800;
  }

  .strength-row strong {
    color: var(--ink);
  }

  .strength-track {
    height: 10px;
    overflow: hidden;
    border-radius: 999px;
    background: #e8eef6;
  }

  .strength-track span {
    display: block;
    width: 25%;
    height: 100%;
    border-radius: inherit;
    background: var(--accent);
    transition:
      width 0.18s ease,
      background 0.18s ease;
  }

  @media (max-width: 520px) {
    .strength-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-password-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const lengthInput = root.querySelector('[data-length]');
    const lengthValue = root.querySelector('[data-length-value]');
    const excludeAmbiguous = root.querySelector('[data-ambiguous]');
    const output = root.querySelector('[data-output]');
    const strength = root.querySelector('[data-strength]');
    const strengthBar = root.querySelector('[data-strength-bar]');
    const error = root.querySelector('[data-error]');
    const toast = root.querySelector('.toast');
    const classes = {
      uppercase: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lowercase: 'abcdefghijklmnopqrstuvwxyz',
      numbers: '0123456789',
      symbols: '!@#$%^&*()-_=+[]{};:,.<>?',
    };
    const ambiguous = /[O0l1I]/g;
    let latest = '';

    function selectedSets() {
      return Array.from(root.querySelectorAll('[data-class]:checked')).map((input) => {
        const key = input.getAttribute('data-class');
        const raw = classes[key] || '';
        return excludeAmbiguous.checked ? raw.replace(ambiguous, '') : raw;
      }).filter(Boolean);
    }

    function randomIndex(max) {
      if (window.crypto?.getRandomValues) {
        const array = new Uint32Array(1);
        // Rejection sampling to avoid modulo bias toward lower indices.
        const limit = Math.floor(0x100000000 / max) * max;
        let value;
        do {
          window.crypto.getRandomValues(array);
          value = array[0];
        } while (value >= limit);
        return value % max;
      }
      return Math.floor(Math.random() * max);
    }

    function pick(chars) {
      return chars[randomIndex(chars.length)];
    }

    function shuffle(items) {
      for (let index = items.length - 1; index > 0; index -= 1) {
        const swap = randomIndex(index + 1);
        [items[index], items[swap]] = [items[swap], items[index]];
      }
      return items;
    }

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function strengthInfo(length, variety) {
      const score = (length >= 12 ? 1 : 0) + (length >= 16 ? 1 : 0) + (length >= 24 ? 1 : 0) + Math.max(0, variety - 1);
      if (score >= 5) return { label: labels.veryStrong, width: '100%', color: '#0f8f8c' };
      if (score >= 4) return { label: labels.strong, width: '75%', color: '#3e63dd' };
      if (score >= 2) return { label: labels.fair, width: '50%', color: '#f59f00' };
      return { label: labels.weak, width: '25%', color: '#f26b4f' };
    }

    function generate() {
      const length = Number(lengthInput.value);
      lengthValue.textContent = String(length);
      const sets = selectedSets();
      if (!sets.length) {
        latest = '';
        output.textContent = '';
        setError(labels.selectOneError);
        return;
      }

      const allChars = sets.join('');
      const chars = sets.map((set) => pick(set));
      while (chars.length < length) {
        chars.push(pick(allChars));
      }
      latest = shuffle(chars).slice(0, length).join('');
      output.textContent = latest;
      const info = strengthInfo(length, sets.length);
      strength.textContent = info.label;
      strengthBar.style.width = info.width;
      strengthBar.style.background = info.color;
      setError('');
    }

    root.querySelector('[data-generate]')?.addEventListener('click', generate);
    root.querySelector('[data-copy]')?.addEventListener('click', async () => {
      if (!latest) return;
      try {
        await navigator.clipboard.writeText(latest);
        toast.hidden = false;
        window.setTimeout(() => {
          toast.hidden = true;
        }, 1500);
      } catch {
        window.prompt(labels.copy, latest);
      }
    });
    root.querySelectorAll('input').forEach((input) => {
      input.addEventListener('input', generate);
      input.addEventListener('change', generate);
    });

    generate();
  });
</script>
