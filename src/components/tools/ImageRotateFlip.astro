---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card image-tool" data-rotate-flip-tool data-labels={JSON.stringify(labels)}>
  <p class="note">{labels.localNote}</p>
  <label>
    <span>{labels.upload}</span>
    <input data-file type="file" accept="image/*" />
  </label>

  <div class="rf-controls">
    <button class="btn ghost" type="button" data-action="left" disabled>{labels.rotateLeft}</button>
    <button class="btn ghost" type="button" data-action="right" disabled>{labels.rotateRight}</button>
    <button class="btn ghost" type="button" data-action="fliph" disabled>{labels.flipH}</button>
    <button class="btn ghost" type="button" data-action="flipv" disabled>{labels.flipV}</button>
    <button class="btn ghost" type="button" data-action="reset" disabled>{labels.resetTransform}</button>
  </div>

  <p class="form-error" data-error role="alert" hidden></p>

  <figure class="rf-preview">
    <figcaption>{labels.preview}</figcaption>
    <img data-preview alt={labels.preview} hidden />
    <span data-empty>{labels.waiting}</span>
  </figure>

  <div class="stats-grid image-stats" aria-live="polite">
    <div><span>{labels.originalSize}</span><strong data-original-size>-</strong></div>
    <div><span>{labels.dimensions}</span><strong data-dimensions>-</strong></div>
  </div>

  <div class="actions">
    <button class="btn go" type="button" data-download disabled>{labels.download}</button>
    <button class="btn ghost" type="button" data-clear>{labels.reset}</button>
  </div>
</section>

<style>
  .rf-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 16px 0;
  }

  .rf-preview {
    display: grid;
    min-height: 240px;
    margin: 0 0 16px;
    padding: 12px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--soft);
  }

  .rf-preview figcaption {
    justify-self: start;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .rf-preview img {
    display: block;
    max-height: 320px;
    border-radius: 8px;
    object-fit: contain;
  }

  .rf-preview span {
    color: var(--muted);
    font-weight: 800;
  }

  .image-stats {
    margin-bottom: 16px;
  }
</style>

<script>
  document.querySelectorAll('[data-rotate-flip-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const fileInput = root.querySelector('[data-file]');
    const preview = root.querySelector('[data-preview]');
    const empty = root.querySelector('[data-empty]');
    const error = root.querySelector('[data-error]');
    const downloadButton = root.querySelector('[data-download]');
    const controlButtons = Array.from(root.querySelectorAll('[data-action]'));
    const out = {
      original: root.querySelector('[data-original-size]'),
      dimensions: root.querySelector('[data-dimensions]'),
    };
    const maxBytes = 20 * 1024 * 1024;
    const maxPixels = 40_000_000;
    let state = null;
    let rotation = 0;
    let flipH = false;
    let flipV = false;
    let outputUrl = '';

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function formatSize(bytes) {
      if (!bytes) return '-';
      return bytes >= 1024 * 1024 ? `${(bytes / 1024 / 1024).toFixed(2)} MB` : `${(bytes / 1024).toFixed(1)} KB`;
    }

    function fileBaseName(name) {
      return name.replace(/\.[^.]+$/, '').replace(/[^\w-]+/g, '-').replace(/^-|-$/g, '') || 'image';
    }

    function outputType() {
      return ['image/jpeg', 'image/png', 'image/webp'].includes(state.file.type) ? state.file.type : 'image/png';
    }

    function extensionFor(type) {
      if (type === 'image/jpeg') return 'jpg';
      if (type === 'image/webp') return 'webp';
      return 'png';
    }

    function revoke() {
      if (outputUrl) URL.revokeObjectURL(outputUrl);
      outputUrl = '';
    }

    function setControlsEnabled(enabled) {
      controlButtons.forEach((b) => { b.disabled = !enabled; });
      downloadButton.disabled = !enabled;
    }

    function clearAll() {
      revoke();
      state = null;
      rotation = 0;
      flipH = false;
      flipV = false;
      fileInput.value = '';
      preview.hidden = true;
      preview.removeAttribute('src');
      empty.hidden = false;
      out.original.textContent = '-';
      out.dimensions.textContent = '-';
      setControlsEnabled(false);
      setError('');
    }

    function readImage(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onerror = reject;
        reader.onload = () => {
          const image = new Image();
          image.onload = () => resolve(image);
          image.onerror = reject;
          image.src = String(reader.result || '');
        };
        reader.readAsDataURL(file);
      });
    }

    async function render() {
      if (!state) return;
      const swap = rotation % 180 !== 0;
      const w = state.image.naturalWidth;
      const h = state.image.naturalHeight;
      const canvas = document.createElement('canvas');
      canvas.width = swap ? h : w;
      canvas.height = swap ? w : h;
      const ctx = canvas.getContext('2d');
      ctx.translate(canvas.width / 2, canvas.height / 2);
      ctx.rotate((rotation * Math.PI) / 180);
      ctx.scale(flipH ? -1 : 1, flipV ? -1 : 1);
      ctx.drawImage(state.image, -w / 2, -h / 2);
      const type = outputType();
      const blob = await new Promise((resolve) => canvas.toBlob(resolve, type, 0.92));
      if (!blob) { setError(labels.processError); return; }
      revoke();
      outputUrl = URL.createObjectURL(blob);
      preview.src = outputUrl;
      preview.hidden = false;
      empty.hidden = true;
      out.dimensions.textContent = `${canvas.width} x ${canvas.height}`;
      downloadButton.dataset.filename = `${state.baseName}-edited.${extensionFor(type)}`;
      setError('');
    }

    async function handleFile() {
      const file = fileInput.files?.[0];
      clearAll();
      if (!file) return;
      if (!file.type.startsWith('image/')) { setError(labels.invalidType); return; }
      if (file.size > maxBytes) { setError(labels.tooLarge); return; }
      try {
        const image = await readImage(file);
        if (image.naturalWidth * image.naturalHeight > maxPixels) { setError(labels.tooLarge); return; }
        state = { file, image, baseName: fileBaseName(file.name) };
        out.original.textContent = formatSize(file.size);
        setControlsEnabled(true);
        await render();
      } catch {
        setError(labels.processError);
      }
    }

    fileInput.addEventListener('change', handleFile);
    controlButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!state) return;
        const action = button.getAttribute('data-action');
        if (action === 'left') rotation = (rotation + 270) % 360;
        else if (action === 'right') rotation = (rotation + 90) % 360;
        else if (action === 'fliph') flipH = !flipH;
        else if (action === 'flipv') flipV = !flipV;
        else if (action === 'reset') { rotation = 0; flipH = false; flipV = false; }
        render();
      });
    });
    root.querySelector('[data-clear]')?.addEventListener('click', clearAll);
    downloadButton.addEventListener('click', () => {
      if (!outputUrl) return;
      const anchor = document.createElement('a');
      anchor.href = outputUrl;
      anchor.download = downloadButton.dataset.filename || 'edited-image';
      anchor.click();
    });
    window.addEventListener('beforeunload', revoke);
  });
</script>
