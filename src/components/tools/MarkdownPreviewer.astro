---
interface Props { labels: Record<string, string>; }
const { labels } = Astro.props;
---
<section class="tool-widget card" data-markdown-tool data-labels={JSON.stringify(labels)}>
  <div class="markdown-grid"><label><span>{labels.input}</span><textarea data-input rows="18" spellcheck="false">## Markdown Preview

Type **Markdown** here.</textarea></label><div><span class="field-title">{labels.preview}</span><article class="preview" data-preview></article></div></div>
  <div class="actions"><button class="btn ghost" type="button" data-copy>{labels.copyHtml}</button><button class="btn ghost" type="button" data-download>{labels.download}</button></div>
</section>
<style>.markdown-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}.markdown-grid textarea{width:100%;min-height:360px}.field-title{display:block;margin-bottom:8px;font-weight:800}.preview{min-height:360px;padding:14px;border:1px solid var(--line);border-radius:8px;background:var(--card);overflow-wrap:anywhere}.preview :global(pre){overflow:auto;padding:12px;background:var(--bg)}.preview :global(img){max-width:100%}@media(max-width:760px){.markdown-grid{grid-template-columns:1fr}}</style>
<script>
  // @ts-nocheck -- DOM nodes are guaranteed by this component template.
  document.querySelectorAll('[data-markdown-tool]').forEach(async(root)=>{const input=root.querySelector('[data-input]');const preview=root.querySelector('[data-preview]');const [{marked},{default:DOMPurify}]=await Promise.all([import('marked'),import('dompurify')]);function render(){preview.innerHTML=DOMPurify.sanitize(marked.parse(input.value,{async:false}));}input.addEventListener('input',render);root.querySelector('[data-copy]')?.addEventListener('click',()=>navigator.clipboard.writeText(preview.innerHTML));root.querySelector('[data-download]')?.addEventListener('click',()=>{const url=URL.createObjectURL(new Blob([preview.innerHTML],{type:'text/html'}));const a=document.createElement('a');a.href=url;a.download='markdown-preview.html';a.click();setTimeout(()=>URL.revokeObjectURL(url),1000);});render();});
</script>
