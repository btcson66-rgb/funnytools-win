---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card image-tool" data-image-compressor-tool data-labels={JSON.stringify(labels)}>
  <p class="note">{labels.localNote}</p>
  <label>
    <span>{labels.upload}</span>
    <input data-file type="file" accept="image/*" />
  </label>

  <div class="form-grid image-controls">
    <label>
      <span>{labels.quality}: <output data-quality-output>80%</output></span>
      <input data-quality type="range" min="10" max="100" value="80" step="1" />
    </label>
    <label>
      <span>{labels.format}</span>
      <select data-format>
        <option value="keep">{labels.keepFormat}</option>
        <option value="image/jpeg">{labels.jpeg}</option>
        <option value="image/webp">{labels.webp}</option>
      </select>
    </label>
  </div>

  <p class="form-error" data-error role="alert" hidden></p>

  <div class="preview-grid">
    <figure>
      <figcaption>{labels.sourcePreview}</figcaption>
      <img data-source-preview alt={labels.sourcePreview} hidden />
      <span data-source-empty>{labels.waiting}</span>
    </figure>
    <figure>
      <figcaption>{labels.outputPreview}</figcaption>
      <img data-output-preview alt={labels.outputPreview} hidden />
      <span data-output-empty>{labels.waiting}</span>
    </figure>
  </div>

  <div class="stats-grid image-stats" aria-live="polite">
    <div><span>{labels.originalSize}</span><strong data-original-size>-</strong></div>
    <div><span>{labels.compressedSize}</span><strong data-output-size>-</strong></div>
    <div><span>{labels.saved}</span><strong data-saved>-</strong></div>
  </div>

  <div class="actions">
    <button class="btn go" type="button" data-download disabled>{labels.download}</button>
    <button class="btn ghost" type="button" data-reset>{labels.reset}</button>
  </div>
</section>

<style>
  select {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    padding: 10px 12px;
    font: inherit;
  }

  .image-controls {
    grid-template-columns: minmax(0, 2fr) minmax(180px, 1fr);
    margin: 16px 0;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin: 18px 0;
  }

  figure {
    display: grid;
    min-height: 240px;
    margin: 0;
    padding: 12px;
    place-items: center;
    border: 1px solid #cfe6e3;
    border-radius: 8px;
    background: #f2fbfa;
  }

  figcaption {
    justify-self: start;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  figure img {
    display: block;
    max-height: 280px;
    border-radius: 8px;
    object-fit: contain;
  }

  figure span {
    color: var(--muted);
    font-weight: 800;
  }

  .image-stats {
    margin-bottom: 16px;
  }

  @media (max-width: 760px) {
    .image-controls,
    .preview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-image-compressor-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const fileInput = root.querySelector('[data-file]');
    const qualityInput = root.querySelector('[data-quality]');
    const qualityOutput = root.querySelector('[data-quality-output]');
    const formatInput = root.querySelector('[data-format]');
    const sourcePreview = root.querySelector('[data-source-preview]');
    const outputPreview = root.querySelector('[data-output-preview]');
    const sourceEmpty = root.querySelector('[data-source-empty]');
    const outputEmpty = root.querySelector('[data-output-empty]');
    const error = root.querySelector('[data-error]');
    const downloadButton = root.querySelector('[data-download]');
    const outputs = {
      original: root.querySelector('[data-original-size]'),
      compressed: root.querySelector('[data-output-size]'),
      saved: root.querySelector('[data-saved]'),
    };
    const maxBytes = 20 * 1024 * 1024;
    const maxPixels = 40_000_000;
    let state = null;
    let outputUrl = '';
    let renderTimer = null;

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function formatSize(bytes) {
      if (!bytes) return '-';
      return bytes >= 1024 * 1024 ? `${(bytes / 1024 / 1024).toFixed(2)} MB` : `${(bytes / 1024).toFixed(1)} KB`;
    }

    function fileBaseName(name) {
      return name.replace(/\.[^.]+$/, '').replace(/[^\w-]+/g, '-').replace(/^-|-$/g, '') || 'image';
    }

    function revokeOutput() {
      if (outputUrl) URL.revokeObjectURL(outputUrl);
      outputUrl = '';
    }

    function clearOutput() {
      revokeOutput();
      outputPreview.hidden = true;
      outputPreview.removeAttribute('src');
      outputEmpty.hidden = false;
      downloadButton.disabled = true;
      outputs.compressed.textContent = '-';
      outputs.saved.textContent = '-';
    }

    let jobId = 0;

    function reset() {
      jobId += 1;
      state = null;
      fileInput.value = '';
      sourcePreview.hidden = true;
      sourcePreview.removeAttribute('src');
      sourceEmpty.hidden = false;
      outputs.original.textContent = '-';
      clearOutput();
      setError('');
    }

    function readImage(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onerror = reject;
        reader.onload = () => {
          const image = new Image();
          image.onload = () => resolve({ image, dataUrl: String(reader.result || '') });
          image.onerror = reject;
          image.src = String(reader.result || '');
        };
        reader.readAsDataURL(file);
      });
    }

    function outputType() {
      if (formatInput.value !== 'keep') return formatInput.value;
      return ['image/jpeg', 'image/png', 'image/webp'].includes(state.file.type) ? state.file.type : 'image/png';
    }

    function extensionFor(type) {
      if (type === 'image/jpeg') return 'jpg';
      if (type === 'image/webp') return 'webp';
      return 'png';
    }

    async function render() {
      if (!state) return;
      const myJob = jobId;
      clearOutput();
      const canvas = document.createElement('canvas');
      canvas.width = state.image.naturalWidth;
      canvas.height = state.image.naturalHeight;
      const context = canvas.getContext('2d');
      context.drawImage(state.image, 0, 0);
      const type = outputType();
      const quality = Number(qualityInput.value) / 100;
      const blob = await new Promise((resolve) => canvas.toBlob(resolve, type, quality));
      if (myJob !== jobId) return;
      if (!blob) {
        setError(labels.processError);
        return;
      }
      outputUrl = URL.createObjectURL(blob);
      outputPreview.src = outputUrl;
      outputPreview.hidden = false;
      outputEmpty.hidden = true;
      outputs.compressed.textContent = formatSize(blob.size);
      const saved = Math.round((1 - blob.size / state.file.size) * 100);
      outputs.saved.textContent = `${saved}%`;
      downloadButton.disabled = false;
      downloadButton.dataset.filename = `${state.baseName}-compressed.${extensionFor(type)}`;
      setError('');
    }

    function scheduleRender() {
      qualityOutput.textContent = `${qualityInput.value}%`;
      window.clearTimeout(renderTimer);
      renderTimer = window.setTimeout(render, 250);
    }

    async function handleFile() {
      const file = fileInput.files?.[0];
      reset();
      const myJob = jobId;
      if (!file) return;
      if (!file.type.startsWith('image/')) {
        setError(labels.invalidType);
        return;
      }
      if (file.size > maxBytes) {
        setError(labels.tooLarge);
        return;
      }
      try {
        const loaded = await readImage(file);
        if (myJob !== jobId) return;
        if (loaded.image.naturalWidth * loaded.image.naturalHeight > maxPixels) {
          setError(labels.tooLarge);
          return;
        }
        state = { file, image: loaded.image, baseName: fileBaseName(file.name) };
        sourcePreview.src = loaded.dataUrl;
        sourcePreview.hidden = false;
        sourceEmpty.hidden = true;
        outputs.original.textContent = formatSize(file.size);
        await render();
      } catch {
        setError(labels.processError);
      }
    }

    fileInput.addEventListener('change', handleFile);
    qualityInput.addEventListener('input', scheduleRender);
    formatInput.addEventListener('change', scheduleRender);
    root.querySelector('[data-reset]')?.addEventListener('click', reset);
    downloadButton.addEventListener('click', () => {
      if (!outputUrl) return;
      const anchor = document.createElement('a');
      anchor.href = outputUrl;
      anchor.download = downloadButton.dataset.filename || 'compressed-image';
      anchor.click();
    });
    window.addEventListener('beforeunload', revokeOutput);
  });
</script>
