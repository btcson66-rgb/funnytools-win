---
import { SITE, type Locale } from '../config/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const ui = t(lang);
const enabled = SITE.features.affiliate;
---

{
  enabled && (
    <section class="content-section reserved-block">
      <h2>{ui.monetization.affiliateHeading}</h2>
      <p>{ui.monetization.affiliateText}</p>
    </section>
  )
}

<style>
  .reserved-block {
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--card);
  }

  .reserved-block p {
    margin: 0;
    color: var(--muted);
  }
</style>
