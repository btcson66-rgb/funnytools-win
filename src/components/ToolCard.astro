---
import type { Locale } from '../config/site';
import CategoryIcon from './CategoryIcon.astro';
import type { ToolMeta } from '../data/tools';
import { t } from '../i18n/ui';
import { toolUrl } from '../lib/url';

interface Props {
  lang: Locale;
  tool: ToolMeta;
}

const { lang, tool } = Astro.props;
const ui = t(lang);
const assetType = tool.assetType ?? 'tool';
---

{
  tool.status === 'live' ? (
    <div
      class="tile tool-tile tool-card tile-linked"
      data-category={tool.category}
      data-tool-id={tool.slug}
      data-tool-name={tool.name[lang]}
      data-tool-category={tool.category}
    >
      <button
        class="favorite-toggle"
        type="button"
        aria-label={ui.favoriteAdd}
        aria-pressed="false"
        data-favorite-toggle
        data-fav-slug={tool.slug}
        data-label-add={ui.favoriteAdd}
        data-label-remove={ui.favoriteRemove}
      >
        <span aria-hidden="true">☆</span>
      </button>
      <span class="tile-icon tool-card__icon"><CategoryIcon category={tool.category} /></span>
      <span class="tile-body tool-card__body">
        <a class="tool-card__link" href={toolUrl(lang, tool.slug)}>
          <strong class="tool-card__title">{tool.name[lang]}</strong>
        </a>
        <span class="tool-card__desc">{tool.short[lang]}</span>
        <span class="asset-type">{ui.assetTypes[assetType]}</span>
        {tool.privacyLevel === 'local-only' && <span class="privacy-badge badge badge--privacy">{ui.privacyBadge}</span>}
        <span class="tool-card__cta">{ui.toolCardCta}</span>
      </span>
      {tool.isNew && <span class="badge">{ui.newest}</span>}
    </div>
  ) : (
    <article class="tile tool-tile tool-card planned" aria-disabled="true" data-category={tool.category}>
      <span class="tile-icon tool-card__icon"><CategoryIcon category={tool.category} /></span>
      <span class="tile-body tool-card__body">
        <strong class="tool-card__title">{tool.name[lang]}</strong>
        <span class="tool-card__desc">{tool.short[lang]}</span>
        <span class="asset-type">{ui.assetTypes[assetType]}</span>
      </span>
      <span class="badge muted">{ui.comingSoon}</span>
    </article>
  )
}

<script>
  import { isFavoriteTool, toggleFavoriteTool } from '../lib/userTools.client';

  function initializeFavoriteToggles() {
    document.querySelectorAll('[data-favorite-toggle]').forEach(function(toggle) {
      if (!(toggle instanceof HTMLButtonElement) || toggle.dataset.favoriteReady === 'true') return;
      const slug = toggle.dataset.favSlug || toggle.closest('[data-tool-id]')?.getAttribute('data-tool-id') || '';
      const labelAdd = toggle.dataset.labelAdd || 'Add to favorites';
      const labelRemove = toggle.dataset.labelRemove || 'Remove from favorites';

      const setState = function(isFavorite) {
        toggle.classList.toggle('is-favorite', isFavorite);
        toggle.setAttribute('aria-pressed', String(isFavorite));
        toggle.setAttribute('aria-label', isFavorite ? labelRemove : labelAdd);
        const icon = toggle.querySelector('[aria-hidden="true"]');
        if (icon) icon.textContent = isFavorite ? '★' : '☆';
      };

      toggle.dataset.favoriteReady = 'true';
      setState(isFavoriteTool(slug));
      toggle.addEventListener('click', function(event) {
        event.preventDefault();
        event.stopPropagation();
        const nextState = toggleFavoriteTool(slug);
        setState(nextState);
        document.dispatchEvent(new CustomEvent('freetools:favorites-changed'));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initializeFavoriteToggles);
  document.addEventListener('freetools:rendered-tools', initializeFavoriteToggles);

  document.querySelectorAll('.tool-card[data-tool-id]').forEach(function(card) {
    card.addEventListener('click', function() {
      if (window.__ft_track) {
        window.__ft_track('tool_card_click', {
          tool_id: card.getAttribute('data-tool-id'),
          tool_name: card.getAttribute('data-tool-name'),
          category: card.getAttribute('data-tool-category')
        });
      }
    });
  });
</script>
