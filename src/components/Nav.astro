---
import LangSwitch from './LangSwitch.astro';
import { SITE, type Locale } from '../config/site';
import { t } from '../i18n/ui';
import { categoryUrl, localePath } from '../lib/url';

interface Props {
  lang: Locale;
  segments?: string[];
  showLangSwitch?: boolean;
}

const { lang, segments = [], showLangSwitch = true } = Astro.props;
const ui = t(lang);
---

<header class="site-nav" data-site-header>
  <div class="nav-inner">
    <a class="brand" href={localePath(lang)} aria-label={SITE.name[lang]}>FunnyTools</a>
    <nav class="nav-links" aria-label={ui.ariaPrimaryNav}>
      <a href={localePath(lang)}>{ui.nav.home}</a>
      <a href={localePath(lang, 'tools')}>{ui.nav.tools}</a>
      {lang === 'zh' && <a href={localePath(lang, 'blog')}>部落格</a>}
      <a href={`${localePath(lang)}#categories`}>{ui.nav.categories}</a>
      <a href={categoryUrl(lang, 'statistics')}>{lang === 'zh' ? '教育與統計' : 'Education & Statistics'}</a>
      <a href={localePath(lang, 'support')}>{lang === 'zh' ? '支持我們' : 'Support'}</a>
    </nav>
    {showLangSwitch && <LangSwitch lang={lang} segments={segments} />}
    <button class="theme-toggle" type="button" aria-label={lang === 'zh' ? '切換深色模式' : 'Toggle dark mode'} data-theme-toggle>
        <svg class="theme-icon theme-icon--moon" aria-hidden="true" viewBox="0 0 24 24"><path d="M20.2 15.6A8.5 8.5 0 0 1 8.4 3.8 8.5 8.5 0 1 0 20.2 15.6Z" /></svg>
        <svg class="theme-icon theme-icon--sun" aria-hidden="true" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.5" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" /></svg>
    </button>
    <button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-navigation" aria-label={lang === 'zh' ? '開啟選單' : 'Open menu'} data-menu-toggle>
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
    </button>
    <nav
      id="mobile-navigation"
      class="mobile-navigation"
      aria-label={ui.ariaMobileNav}
      aria-hidden="true"
      data-mobile-nav
      hidden
    >
      <a href={localePath(lang)}>{ui.nav.home}</a>
      <a href={localePath(lang, 'tools')}>{ui.nav.tools}</a>
      {lang === 'zh' && <a href={localePath(lang, 'blog')}>部落格</a>}
      <a href={`${localePath(lang)}#categories`}>{ui.nav.categories}</a>
      <a href={categoryUrl(lang, 'statistics')}>{lang === 'zh' ? '教育與統計' : 'Education & Statistics'}</a>
      <a href={localePath(lang, 'support')}>{lang === 'zh' ? '支持我們' : 'Support'}</a>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem('theme', next); } catch {}
    });

    const toggle = document.querySelector('[data-menu-toggle]');
    const menu = document.querySelector('[data-mobile-nav]');
    toggle?.addEventListener('click', () => {
      if (!(menu instanceof HTMLElement)) return;
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      menu.hidden = open;
      menu.setAttribute('aria-hidden', String(open));
    });
  })();
</script>
