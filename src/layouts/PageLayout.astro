---
import Breadcrumb from '../components/Breadcrumb.astro';
import BaseLayout from './BaseLayout.astro';
import { type Locale } from '../config/site';
import { t } from '../i18n/ui';
import { localePath, localeUrlPair } from '../lib/url';
import { breadcrumbJsonLd, webPageJsonLd } from '../lib/seo';

interface PageLink {
  href: string;
  label: string;
  note?: string;
}

interface Props {
  lang: Locale;
  title: string;
  seoTitle: string;
  description: string;
  pageKey: string;
  body: string[];
  extraLinks?: PageLink[];
}

const { lang, title, seoTitle, description, pageKey, body, extraLinks = [] } = Astro.props;
const ui = t(lang);
const breadcrumbItems = [
  { name: ui.breadcrumbHome, href: localePath(lang) },
  { name: title, href: localePath(lang, pageKey) },
];
const jsonLd = [
  webPageJsonLd(lang, title, description, localePath(lang, pageKey)),
  breadcrumbJsonLd(breadcrumbItems),
];
---

<BaseLayout lang={lang} title={seoTitle} description={description} alternateSegments={[pageKey]} altLang={localeUrlPair(pageKey)} jsonLd={jsonLd}>
  <section class="wrap page-head">
    <Breadcrumb
      items={[
        { label: ui.breadcrumbHome, href: localePath(lang) },
        { label: title },
      ]}
    />
    <h1>{title}</h1>
  </section>
  <section class="wrap prose-page">
    {body.map((paragraph) => <p>{paragraph}</p>)}
    {extraLinks.length > 0 && (
      <div class="page-link-list">
        {extraLinks.map((link) => (
          <a href={link.href} rel="noopener">
            <strong>{link.label}</strong>
            {link.note && <span>{link.note}</span>}
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .page-link-list {
    display: grid;
    gap: 10px;
    margin-top: 24px;
  }

  .page-link-list a {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--card);
  }

  .page-link-list a:hover {
    border-color: var(--brand);
  }

  .page-link-list span {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
