---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import { SITE, type Locale } from '../config/site';
import { absoluteUrl, localePath } from '../lib/url';
import { buildHreflang, defaultOgImage } from '../lib/seo';

interface Props {
  lang: Locale;
  title: string;
  description: string;
  type?: 'website' | 'article';
  alternateSegments?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  lang,
  title,
  description,
  type = 'website',
  alternateSegments = [],
  jsonLd = [],
} = Astro.props;

const canonical = absoluteUrl(localePath(lang, ...alternateSegments));
const hreflangs = buildHreflang(alternateSegments);
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const ogLocale = lang === 'zh' ? 'zh_TW' : 'en_US';
const ogImage = defaultOgImage();
---

<!doctype html>
<html lang={SITE.htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {hreflangs.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name[lang]} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    {
      (SITE.adsenseEnabled || SITE.features.adsense) && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <Nav lang={lang} segments={alternateSegments} />
    <main id="content" class="site-main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
