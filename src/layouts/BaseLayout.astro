---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import { SITE, type Locale } from '../config/site';
import indexingConfig from '../config/indexing.json';
import { absoluteUrl, assetPath, localePath } from '../lib/url';
import { defaultOgImage } from '../lib/seo';
import { t } from '../i18n/ui';

type AltLang = Record<Locale, string>;

interface Props {
  lang: Locale;
  title: string;
  description: string;
  keywords?: string[];
  type?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  alternateSegments?: string[];
  altLang?: AltLang;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  hasAlternates?: boolean;
  robots?: string;
}

const {
  lang,
  title,
  description,
  keywords = [],
  type = 'website',
  ogImage: customOgImage,
  ogImageAlt,
  alternateSegments = [],
  altLang,
  jsonLd = [],
  noindex = false,
  hasAlternates: explicitHasAlternates,
  robots,
} = Astro.props;

const canonical = absoluteUrl(localePath(lang, ...alternateSegments));
const hreflangs = altLang
  ? [
      { hreflang: SITE.hreflang.zh, href: absoluteUrl(altLang.zh) },
      { hreflang: SITE.hreflang.en, href: absoluteUrl(altLang.en) },
      { hreflang: 'x-default', href: absoluteUrl(altLang.zh) },
    ]
  : [];
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const ogLocale = lang === 'zh' ? 'zh_TW' : 'en_US';
const ogImage = customOgImage ?? defaultOgImage();
const ogAlt = ogImageAlt ?? SITE.name[lang];
const brandedTitle = title.includes('FunnyTools') ? title : `${title} - FunnyTools`;
const brandedDescription = description;
const ui = t(lang);
const enNoindex = indexingConfig.EN_NOINDEX === true && lang === 'en';
const shouldNoindex = noindex || enNoindex;
const robotsContent = enNoindex ? 'noindex, follow' : (robots ?? 'noindex, follow');
const envAdsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? import.meta.env.PUBLIC_ADSENSE_ID;
const adsenseClient = envAdsenseClient ?? SITE.adsenseClient;
const adsenseEnabled = Boolean(adsenseClient) && (SITE.adsenseEnabled || SITE.features.adsense);
const hasAlternates = explicitHasAlternates ?? Boolean(altLang);
const ga4Enabled = !!SITE.ga4MeasurementId;
const contentSecurityPolicy = [
  "default-src 'self'",
  `script-src 'self' 'unsafe-inline'${ga4Enabled ? ' https://www.googletagmanager.com' : ''}${adsenseEnabled ? ' https://pagead2.googlesyndication.com https://www.googletagservices.com https://adservice.google.com https://*.adtrafficquality.google' : ''}`,
  "style-src 'self' 'unsafe-inline'",
  `img-src 'self' data: blob:${ga4Enabled ? ' https://www.googletagmanager.com' : ''}${adsenseEnabled ? ' https://pagead2.googlesyndication.com https://*.googleusercontent.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://*.adtrafficquality.google' : ''}`,
  `frame-src 'self'${adsenseEnabled ? ' https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://*.adtrafficquality.google https://www.google.com' : ''}`,
  `connect-src 'self'${ga4Enabled ? ' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://analytics.google.com' : ''}${adsenseEnabled ? ' https://pagead2.googlesyndication.com https://*.adtrafficquality.google https://googleads.g.doubleclick.net https://csi.gstatic.com' : ''}`,
  "object-src 'none'",
  "base-uri 'self'",
  "form-action 'self'",
].join('; ');
---

<!doctype html>
<html lang={SITE.htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="icon" href={assetPath('favicon.ico')} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={assetPath('favicon.svg')} />
    <link rel="apple-touch-icon" sizes="180x180" href={assetPath('apple-touch-icon.png')} />
    <link rel="manifest" href={assetPath('manifest.webmanifest')} />
    <meta name="theme-color" content="#0d9488" />
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          const preferred = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.dataset.theme = saved || preferred;
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <title>{brandedTitle}</title>
    <meta name="description" content={brandedDescription} />
    {shouldNoindex ? <meta name="robots" content={robotsContent} /> : <link rel="canonical" href={canonical} />}
    {!shouldNoindex && robots && <meta name="robots" content={robots} />}
    {!shouldNoindex && altLang && hreflangs.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
    <meta property="og:type" content={type} />
    <meta property="og:title" content={brandedTitle} />
    <meta property="og:description" content={brandedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogAlt} />
    <meta property="og:site_name" content={SITE.name[lang]} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={brandedTitle} />
    <meta name="twitter:description" content={brandedDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogAlt} />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    {
      ga4Enabled && (
        <>
          <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.ga4MeasurementId}`} />
          <script is:inline define:vars={{ measurementId: SITE.ga4MeasurementId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            // Consent Mode v2: default denied in EEA/UK/CH until a certified CMP
            // (AdSense Privacy & messaging) collects consent; granted elsewhere.
            gtag('consent', 'default', {
              ad_storage: 'denied',
              ad_user_data: 'denied',
              ad_personalization: 'denied',
              analytics_storage: 'denied',
              wait_for_update: 500,
              region: ['AT','BE','BG','HR','CY','CZ','DK','EE','FI','FR','DE','GR','HU','IS','IE','IT','LV','LI','LT','LU','MT','NL','NO','PL','PT','RO','SK','SI','ES','SE','GB','CH'],
            });
            gtag('consent', 'default', {
              ad_storage: 'granted',
              ad_user_data: 'granted',
              ad_personalization: 'granted',
              analytics_storage: 'granted',
            });
            gtag('js', new Date());
            gtag('config', measurementId);
          </script>
          <script is:inline>
            window.__ft_track = function(eventName, params) {
              if (typeof window.gtag === 'function') {
                var forbiddenNames = [
                  'in' + 'put',
                  'in' + 'put_' + 'value',
                  'user_' + 'in' + 'put',
                  'raw_' + 'value',
                  'text',
                  'result_' + 'text',
                  'file_' + 'name',
                  'file' + 'name',
                  'student_' + 'name',
                  'student_' + 'names',
                  'grade',
                  'grades',
                  'research_' + 'data',
                  'pass' + 'word',
                  'qr_' + 'payload'
                ];
                var base = {
                  page_path: window.location.pathname,
                  language: document.documentElement.lang || 'zh-Hant'
                };
                var merged = {};
                for (var k in base) merged[k] = base[k];
                if (params) {
                  for (var k in params) {
                    if (forbiddenNames.indexOf(String(k).toLowerCase()) === -1) merged[k] = params[k];
                  }
                }
                window.gtag('event', eventName, merged);
              }
            };
          </script>
        </>
      )
    }
    {
      adsenseEnabled && (
        <>
          <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
          <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
        </>
      )
    }
    {
      adsenseEnabled && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#content">{ui.skipToContent}</a>
    <Nav lang={lang} segments={alternateSegments} showLangSwitch={hasAlternates} />
    <main id="content" class="site-main">
      <slot />
    </main>
    <Footer lang={lang} />
    <script src={assetPath('install-prompt.js')} defer></script>
    <script is:inline>
      // Lightweight speculative prefetch: warm the HTTP cache for same-origin
      // pages when the user hovers or touches a link.
      (() => {
        if (navigator.connection && (navigator.connection.saveData || /2g/.test(navigator.connection.effectiveType || ''))) return;
        const seen = new Set();
        const prefetch = (event) => {
          const link = event.target instanceof Element ? event.target.closest('a[href]') : null;
          if (!link || link.origin !== location.origin || link.target === '_blank' || link.hasAttribute('download')) return;
          const url = link.href.split('#')[0];
          if (!url || seen.has(url) || url === location.href.split('#')[0]) return;
          seen.add(url);
          const hint = document.createElement('link');
          hint.rel = 'prefetch';
          hint.href = url;
          hint.as = 'document';
          document.head.append(hint);
        };
        document.addEventListener('mouseover', prefetch, { passive: true });
        document.addEventListener('touchstart', prefetch, { passive: true });
      })();
    </script>
  </body>
</html>
